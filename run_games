#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

pnpm dev:logs &
LOGS_PID=$!
trap 'kill $LOGS_PID 2>/dev/null || true' EXIT INT TERM

# Wait for log server to bind to port 9999 (dev:games refuses to start without it)
for _ in $(seq 1 50); do
    if (echo > /dev/tcp/localhost/9999) 2>/dev/null; then
        break
    fi
    sleep 0.2
done

pnpm dev:games
