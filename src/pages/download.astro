// filepath: /Users/oloflandin/Programming/JordglobeSite/src/pages/download.astro
// Use the request headers to detect the user's device and redirect accordingly.
const userAgent = Astro.request.headers.get('user-agent') || '';
const referrer = Astro.request.headers.get('referer') || '';

const androidUrl = "https://play.google.com/store/apps/details?id=com.linbasta.jordglobegeo";
const iosUrl = "https://apps.apple.com/app/id1599500931"; 

// Check if user came from our homepage
const isFromHomepage = referrer.includes(Astro.url.origin + '/');

if (/android/i.test(userAgent)) {
    return Astro.redirect(androidUrl);
} else if (/iPhone|iPad|iPod/i.test(userAgent)) {
    return Astro.redirect(iosUrl);
} else if (isFromHomepage) {
    // Show Android store for homepage visitors
    return Astro.redirect(androidUrl);
} else {
    // Redirect to home for visitors from other sources
    return Astro.redirect('/');
}
