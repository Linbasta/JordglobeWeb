---
// layout
import BaseLayout from "@layouts/BaseLayout.astro";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { getTranslatedData } from "@js/translationUtils";

// images
import place1 from "@images/aniket_p.jpg";
import place2 from "@images/place-for-photo.png";
import place3 from "@images/place-for-photo.png";
import place4 from "@images/place-for-photo.png";
import place5 from "@images/place-for-photo.png";
import place6 from "@images/place-for-photo.png";
import place7 from "@images/place-for-photo.png";
import place8 from "@images/place-for-photo.png";
import place9 from "@images/place-for-photo.png";

// data
const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);

// Trivia items data
const triviaItems = [
  {
    title: "Trivia 1",
    image: place1.src,
    link: "https://quiz.jordglobe.com",
    description: "Interesting fact about trivia 1"
  },
  {
    title: "Trivia 2",
    image: place2.src,
    link: "/trivia/2",
    description: "Interesting fact about trivia 2"
  },
  {
    title: "Trivia 3",
    image: place3.src,
    link: "/trivia/3",
    description: "Interesting fact about trivia 3"
  },
  {
    title: "Trivia 4",
    image: place4.src,
    link: "/trivia/4",
    description: "Interesting fact about trivia 4"
  },
  {
    title: "Trivia 5",
    image: place5.src,
    link: "/trivia/5",
    description: "Interesting fact about trivia 5"
  },
  {
    title: "Trivia 6",
    image: place6.src,
    link: "/trivia/6",
    description: "Interesting fact about trivia 6"
  },
  {
    title: "Trivia 7",
    image: place7.src,
    link: "/trivia/7",
    description: "Interesting fact about trivia 7"
  },
  {
    title: "Trivia 8",
    image: place8.src,
    link: "/trivia/8",
    description: "Interesting fact about trivia 8"
  },
  {
    title: "Trivia 9",
    image: place9.src,
    link: "/trivia/9",
    description: "Interesting fact about trivia 9"
  }
];
---

<BaseLayout title="Trivia - " + {siteData.title} description="Explore interesting trivia about our world">
  <div class="container mx-auto px-4 py-16">
    <h1 class="text-4xl font-bold text-center mb-12">World Trivia</h1>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {triviaItems.map((item) => (
        <a href={item.link} class="group">
          <div class="bg-white rounded-lg shadow-lg overflow-hidden transition-transform duration-300 hover:scale-105">
            <div class="aspect-w-16 aspect-h-9">
              <img
                src={item.image}
                alt={item.title}
                class="w-full h-full object-cover"
              />
            </div>
            <div class="p-6">
              <h2 class="text-xl font-semibold mb-2 group-hover:text-blue-600 transition-colors">
                {item.title}
              </h2>
              <p class="text-gray-600">
                {item.description}
              </p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .aspect-w-16 {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
  }
  
  .aspect-w-16 img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style> 