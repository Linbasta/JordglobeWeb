---
export const prerender = true;
import duelBannerImage from '@images/duel_banner.jpg';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Jordglobe - Duel</title>
    <style>
      body {
        font-family: sans-serif;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        margin: 0;
        background-color: #f0f2f5;
        color: #333;
        text-align: center;
      }
      .container {
        background: white;
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        max-width: 500px;
        width: 90%;
      }
      h1 {
        color: #2c3e50;
        margin-bottom: 20px;
      }
      p {
        margin-bottom: 30px;
        line-height: 1.6;
      }
      .button-container {
        display: flex;
        flex-direction: column;
        gap: 15px;
      }
      .app-button {
        display: inline-block;
        padding: 12px 25px;
        background-color: #007bff;
        color: white;
        text-decoration: none;
        border-radius: 8px;
        font-size: 1.1em;
        transition: background-color 0.3s ease;
      }
      .app-button:hover {
        background-color: #0056b3;
      }
      .banner-image {
        width: 100%;
        max-width: 400px;
        height: auto;
        margin-bottom: 20px;
        border-radius: 8px;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <img src={duelBannerImage.src} alt="Jordglobe Duel" class="banner-image" />
      <h1>Download the JordGlobe App</h1>
      <p>
        To join the duel, you need to have the JordGlobe app installed on your device.
        Click the button below to download the app.
      </p>
      <div class="button-container">
        <a id="downloadAppButton" class="app-button" href="#" style="background-color: #28a745;">Download from Store</a>
      </div>
    </div>

    <script>
      window.onload = () => {
        const downloadAppButton = document.getElementById('downloadAppButton');
        
        const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent);
        const isAndroid = /Android/.test(navigator.userAgent);

        let storeUrl = "https://apps.apple.com/app/id1599500931"; // Apple App Store
        if (isAndroid) {
            storeUrl = "https://play.google.com/store/apps/details?id=com.linbasta.jordglobegeo"; // Google Play Store
        }

        downloadAppButton.href = storeUrl;
        
        // Also redirect automatically after a delay
        setTimeout(() => {
          window.location.href = storeUrl;
        }, 2000);
      };
    </script>
  </body>
</html> 