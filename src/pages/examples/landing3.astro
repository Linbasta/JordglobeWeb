---
// layout
import BaseLayout from "@layouts/BaseLayout.astro";

// components
import HeroSideImage from "@components/Hero/HeroSideImage.astro";
import HeroCentered from "@components/Hero/HeroCentered.astro";
import HeroCenteredImages from "@components/Hero/HeroCenteredImages.astro";

import LogoCloudStatic from "@components/LogoCloud/LogoCloudStatic.astro";
import LogoCloudMarquee from "@components/LogoCloud/LogoCloudMarquee.astro";

import FeatureBento from "@components/Feature/FeatureBento.astro";
import FeatureThreeImage from "@components/Feature/FeatureThreeImage.astro";
import FeatureCardsSmall from "@components/Feature/FeatureCardsSmall.astro";
import FeatureCardsSmall2 from "@components/Feature/FeatureCardsSmall2.astro";
import FeatureCardsMedium from "@components/Feature/FeatureCardsMedium.astro";
import FeatureVideo from "@components/Feature/FeatureVideo.astro";
import FeatureSideImage from "@components/Feature/FeatureSideImage.astro";
import FeatureSimple from "@components/Feature/FeatureSimple.astro";
import FeatureSteps from "@components/Feature/FeatureSteps.astro";
import FeatureIntegrations from "@components/Feature/FeatureIntegrations.astro";
import FeatureNumbers from "@components/Feature/FeatureNumbers.astro";

import TestimonialsSwiperQuotes from "@components/Testimonials/TestimonialsSwiperQuotes.astro";
import TestimonialsColumns from "@components/Testimonials/TestimonialsColumns.astro";
import TestimonialsRows from "@components/Testimonials/TestimonialsRows.astro";

import PricingThreeCards from "@components/Pricing/PricingThreeCards.astro";
import PricingFourCards from "@components/Pricing/PricingFourCards.astro";
import PricingOnePrice from "@components/Pricing/PricingOnePrice.astro";
import PricingTable from "@components/Pricing/PricingTable.astro";

import CtaImage from "@components/Cta/CtaImage.astro";
import CtaCardLeft from "@components/Cta/CtaCardLeft.astro";
import CtaCenter from "@components/Cta/CtaCenter.astro";

import FaqAccordions from "@components/Faq/FaqAccordions.astro";
import FaqCards from "@components/Faq/FaqCards.astro";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { getTranslatedData } from "@js/translationUtils";

// data
const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);
---

<BaseLayout title={siteData.title} description={siteData.description} noindex={true}>
	<HeroCentered />
	<LogoCloudMarquee />
	<FeatureVideo />
	<FeatureCardsMedium />
	<FeatureSideImage />
	<FeatureCardsSmall />
	<TestimonialsSwiperQuotes />
	<PricingOnePrice />
	<CtaCardLeft />
	<FaqAccordions />
</BaseLayout>
