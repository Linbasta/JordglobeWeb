---
// If you're using images from src folder:
import appStoreBadge from "@images/app-store-badge.svg";
import googlePlayBadge from "@images/google-play-badge.png";
// If images are in public folder, you can reference them directly with /images/...
---

<div class="mx-auto max-w-2xl px-4 py-12">
	<h1 class="mb-6 text-5xl font-bold">Play Jordglobe</h1>

	<h2 class="mb-8 text-xl text-gray-600">Download Jordglobe here and start your journey!</h2>

	<div class="flex flex-wrap items-center gap-4">
		<a href="https://apps.apple.com/se/app/jordglobe/id1599500931?l=en" class="h-auto w-40">
			<img src={appStoreBadge.src} alt="Download on the App Store" class="h-auto w-full" />
		</a>

		<a
			href="https://play.google.com/store/apps/details?id=com.linbasta.jordglobegeo"
			class="h-auto w-40"
		>
			<img src={googlePlayBadge.src} alt="Get it on Google Play" class="h-auto w-full" />
		</a>
	</div>
</div>
