---
/**
 * * This is a 3 card bento grid. Each card has a title, text, and "learn more" link.
 * All user-facing strings are now localized via siteData.
 */

import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import { getLocaleFromUrl } from "@js/localeUtils";
import { getTranslatedData } from "@js/translationUtils";

// components
import Badge from "@components/Badge/Badge.astro";

// images
import card1img1 from "@images/front/countries.png";
import card2img from "@images/front/cities.png";
import card3img from "@images/front/trivia.png";

// get localized data
const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);
const fBent = siteData.featureBento;
---

<section id="feature-bento" class="feature-section overflow-hidden py-16 md:py-24">
    <div class="site-container">
        <div class="mx-auto mb-20 max-w-2xl text-center">
            <Badge>{fBent.badgeText}</Badge>
            <h2 class="h2">{fBent.sectionTitle}</h2>
        </div>
        <div class="mx-auto max-w-7xl">
            <div class="-m-4 flex flex-wrap">
                <div class="w-full p-4 md:w-1/2">
                    <div class="-m-4 flex flex-wrap">
                        <!-- card 1 -->
                        <div class="w-full p-4">
                            <div class="relative flex flex-col items-center justify-center rounded-lg p-8" style="border: 2px solid var(--card-border-color);">
                                <h3 class="h3 mb-4 font-semibold" style="letter-spacing: -0.5px;">
                                    {fBent.card1Title}
                                </h3>
                                <p class="description mb-9 tracking-tight md:max-w-sm text-center" style="line-height: 1.6 !important; letter-spacing: 0.5px !important;">
                                    {fBent.card1Description}
                                </p>
                                <Image
                                    src={card1img1}
                                    alt={fBent.card1ImageAlt}
                                    loading="lazy"
                                    class="w-full max-w-xs h-auto mb-10"
                                />
                                <a
                                    class="description hover:text-primary-500 dark:hover:text-primary-500 relative z-10 flex items-center font-semibold tracking-tight transition duration-200"
                                    href="/downloadfromsite"
                                >
                                    <span class="mr-2.5">
                                        <span class="sr-only">{fBent.ctaSrText}</span>
                                        {fBent.learnMoreText}
                                    </span>
                                    <Icon name="nova/arrow-angled" aria-hidden="true" class="size-6" />
                                </a>
                            </div>
                        </div>
                        <!-- card 2 -->
                        <div class="w-full p-4">
                            <div class="relative flex flex-col items-center justify-center overflow-hidden rounded-lg p-8" style="border: 2px solid var(--card-border-color);">
                                <h3 class="h3 mb-4 font-semibold" style="letter-spacing: -0.5px;">
                                    {fBent.card2Title}
                                </h3>
                                <p class="description mb-4 tracking-tight md:max-w-sm text-center" style="line-height: 1.6 !important; letter-spacing: 0.5px !important;">
                                    {fBent.card2Description}
                                </p>
                                <Image
                                    src={card2img}
                                    alt={fBent.card2ImageAlt}
                                    loading="lazy"
                                    class="w-full max-w-md h-auto mb-4"
                                />
                                <a
                                    class="description hover:text-primary-500 dark:hover:text-primary-500 relative z-10 flex items-center font-semibold tracking-tight transition duration-200"
                                    href="/downloadfromsite"
                                    style="letter-spacing: 0.5px;"
                                >
                                    <span class="mr-2.5">
                                        <span class="sr-only">{fBent.ctaSrText}</span>
                                        {fBent.learnMoreText}
                                    </span>
                                    <Icon name="nova/arrow-angled" aria-hidden="true" class="size-6" />
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- card 3 -->
                <div class="w-full p-4 md:w-1/2">
                    <div class="relative h-full overflow-hidden rounded-lg p-8 flex flex-col items-center" style="border: 2px solid var(--card-border-color);">
                        <h3 class="h3 mb-4 font-semibold text-center" style="letter-spacing: -0.5px;">
                            {fBent.card3Title}
                        </h3>
                        <p class="description mb-10 tracking-tight md:max-w-sm text-center" style="line-height: 1.6 !important; letter-spacing: 0.5px !important;">
                            {fBent.card3Description}
                        </p>
                        <a
                            class="description hover:text-primary-500 dark:hover:text-primary-500 relative z-10 mb-4 flex items-center font-semibold tracking-tight transition duration-200 text-center"
                            href="/downloadfromsite"
                        >
                            <span class="mr-2.5">
                                <span class="sr-only">{fBent.ctaSrText}</span>
                                {fBent.learnMoreText}
                            </span>
                            <Icon name="nova/arrow-angled" aria-hidden="true" class="size-6" />
                        </a>
                        <div class="mx-auto max-w-max flex-grow flex items-center">
                            <Image
                                src={card3img}
                                alt={fBent.card3ImageAlt}
                                loading="lazy"
                                class="w-full h-full object-contain transform transition duration-500 hover:-translate-y-2"
                            />
                        </div>
                        <a
                            class="from-gradient-1 via-gradient-2 to-gradient-3 focus:ring-primary-300 mb-6 flex w-full items-center rounded-lg bg-linear-40 px-3.5 py-5 font-medium tracking-tight text-white transition duration-500 focus:ring-4 text-center"
                            href="/downloadfromsite"
                        >
                            <div class="mr-3 inline-block">
                                <Icon name="nova/circle-check" aria-hidden="true" class="size-6" />
                            </div>
                            <span>{fBent.paymentInfoText}</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
