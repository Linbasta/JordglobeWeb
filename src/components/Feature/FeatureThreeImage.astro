---
/**
 * * Feature section with 3 main images, each with title and text above them
 */

import { Image } from "astro:assets";
import { getLocaleFromUrl } from "@js/localeUtils";
import { getTranslatedData } from "@js/translationUtils";

// get localized data
const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);

interface FeatureData {
	title: string;
	text: string;
	image: ImageMetadata;
}

// data
const featureData: FeatureData[] = siteData.featureThreeImage;
---

<section
	id="feature-three-image"
	class="bg-base-950 dark:bg-base-900 overflow-hidden py-16 md:py-24"
>
	<div class="site-container">
		<h2 class="h2 text-base-100 mb-12 lg:mb-24">How to streamline your workflow</h2>
		<div class="-m-5 flex flex-wrap" id="trigger-three-img">
			{
				featureData.map((feature, idx) => (
					<div
						class="w-full p-5 md:w-1/3"
						data-aos="fade-up"
						data-aos-delay={0.2 * idx}
						data-aos-trigger="#trigger-three-img"
					>
						<h3 class="text-base-100 mb-4 text-xl font-semibold tracking-tight">{feature.title}</h3>
						<p class="text-base-400 dark:text-base-300 mb-12 text-xl tracking-tight">
							{feature.text}
						</p>
						<Image
							src={feature.image}
							alt="image"
							loading="lazy"
							width={600}
							class="w-full transform rounded-lg transition duration-500 hover:translate-y-3"
							aria-hidden="true"
						/>
					</div>
				))
			}
		</div>
	</div>
</section>
