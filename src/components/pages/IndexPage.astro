---
// layout
import BaseLayout from "@layouts/BaseLayout.astro";

// components
import HeroSideImage from "@components/Hero/HeroSideImage.astro";
import FeatureBento from "@components/Feature/FeatureBento.astro";
import FeatureThreeImage from "@components/Feature/FeatureThreeImage.astro";
import FeatureCardsSmall2 from "@components/Feature/FeatureCardsSmall2.astro";
import FeatureVideo from "@components/Feature/FeatureVideo.astro";
import TestimonialsRows from "@components/Testimonials/TestimonialsRows.astro";
import FaqAccordions from "@components/Faq/FaqAccordions.astro";
import HeroVideo from '@components/Hero/HeroVideo.astro';
import HeroDownload from '@components/Hero/HeroDownload.astro';
import logoImage from '@images/jordglobe-logo.png';
import posterImage from '@images/front/first-frame.jpg';

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { getTranslatedData } from "@js/translationUtils";

// data
const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);
---

<BaseLayout title={siteData.title} description={siteData.description}>
	<HeroVideo
		videoSrc="/assets/globe.m4v"
		videoSrcMobile="/assets/globe-mobile.m4v"
		posterSrc={posterImage.src}
		logoSrc={logoImage}
		logoAlt="Your Logo"
		overlayColor="rgb(0,0,0)"
		overlayOpacity="0.43"
	/>
	<HeroDownload />
	<FeatureBento />
	<FeatureThreeImage />
	<HeroSideImage />
	<FeatureCardsSmall2 />
	<FeatureVideo />
	<TestimonialsRows />
	<FaqAccordions />
</BaseLayout>
