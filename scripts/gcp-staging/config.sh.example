#!/bin/bash
#
# GCP Staging Server Configuration
#
# Copy this file to config.sh and fill in your values:
#   cp config.sh.example config.sh
#
# NOTE: config.sh is gitignored to keep credentials private

# GCP Configuration
export GCP_PROJECT="your-gcp-project-id"
export GCP_ZONE="us-central1-a"
export GCP_INSTANCE_NAME="jordglobe-staging"
export GCP_MACHINE_TYPE="e2-small"
export GCP_DISK_SIZE="10GB"

# Server Configuration (auto-populated after server creation)
export SERVER_IP=""
export SERVER_USER="your-username"

# Application Configuration
export APP_DIR="/home/${SERVER_USER}/jordglobe"
export APP_PORT="8080"

# Basic Auth (for team access)
export BASIC_AUTH_USER="team"
export BASIC_AUTH_PASSWORD="changeme123"

# Node.js version
export NODE_VERSION="20"
