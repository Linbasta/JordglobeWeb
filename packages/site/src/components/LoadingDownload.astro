---
import appStoreBadge from "@images/app-store-badge.svg";
import googlePlayBadge from "@images/google-play-badge.png";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow">
    <title>Downloading Jordglobe</title>
  </head>
  <body>
    <div class="download-container">
      <div class="spinner"></div>
      <h1>Redirecting</h1>
      <p>Soon you'll arrive at the correct location</p>
      
      <div id="manual-downloads" class="hidden">
        <p class="fallback-text">If you're not redirected automatically, please use these links:</p>
        <div class="store-links">
          <a href="https://apps.apple.com/se/app/jordglobe/id1599500931?l=en">
            <img src={appStoreBadge.src} alt="Download on App Store" class="store-badge" />
          </a>
          <a href="https://play.google.com/store/apps/details?id=com.linbasta.jordglobegeo">
            <img src={googlePlayBadge.src} alt="Get it on Google Play" class="store-badge" />
          </a>
        </div>
      </div>
    </div>
  </body>
</html>

<style>
  .download-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 80vh;
    text-align: center;
  }

  .spinner {
    width: 50px;
    height: 50px;
    border: 5px solid #f3f3f3;
    border-top: 5px solid #3498db;
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin-bottom: 2rem;
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  h1 {
    margin-bottom: 1rem;
  }

  .hidden {
    display: none;
  }

  .fallback-text {
    margin: 2rem 0 1rem;
    color: #666;
  }

  .store-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin-top: 1rem;
  }

  .store-badge {
    height: 48px;
    width: auto;
  }
</style>

<script>
  setTimeout(() => {
    const manualDownloads = document.getElementById('manual-downloads');
    if (manualDownloads) {
      manualDownloads.classList.remove('hidden');
    }
  }, 3000);
</script>
