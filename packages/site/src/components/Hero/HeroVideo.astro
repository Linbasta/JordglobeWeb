---
/**
 * Hero section with fullscreen video background,
 * showing a poster image (first video frame) until the video is ready.
 */
import { Image } from "astro:assets";

interface Props {
    videoSrc: string;
    videoSrcMobile: string; // Add mobile video source
    posterSrc: string; // first frame image
    logoSrc: string;
    logoAlt: string;
    overlayColor?: string;
    overlayOpacity?: string;
}

const {
    videoSrc,
    videoSrcMobile,
    posterSrc,
    logoSrc,
    logoAlt,
    overlayColor = "rgb(0,0,0)",
    overlayOpacity = "0",
} = Astro.props;
---

<section id="feature-video" 
    class="relative h-screen w-full overflow-hidden"
    data-video-desktop={videoSrc}
    data-video-mobile={videoSrcMobile}
>
    <!-- Video Background -->
    <div class="absolute inset-0 h-full w-full">
        <video id="hero-video" autoplay loop muted playsinline class="h-full w-full object-cover">
            <source id="video-source" src={videoSrc} type="video/mp4" />
            Your browser does not support the video tag.
        </video>
    </div>

    <!-- Poster Overlay (First Video Frame) -->
    <!-- z-10 keeps it above the bg <video> but below the logo (z-20) and the
         fixed navbar (z-30 in BaseLayout's Nav). Without this it covered the
         navbar until the video's `loadeddata` event fired. -->
    <div
        id="poster-overlay"
        class="absolute inset-0 z-10 bg-cover bg-center pointer-events-none"
        style={`background-image: url('${posterSrc}');`}
    >
    </div>

    <!-- Content -->
    <div class="relative z-20 flex h-full w-full items-center justify-center px-4">
        <div class="animate-fadeIn w-full max-w-[500px]">
            <Image src={logoSrc} alt={logoAlt} class="w-full" width={700} height={400} loading="eager" />
        </div>
    </div>
</section>

<script>
    function initHeroVideo() {
        const featureVideo = document.getElementById("feature-video");
        const video = document.getElementById("hero-video") as HTMLVideoElement | null;
        const videoSource = document.getElementById("video-source") as HTMLSourceElement | null;
        const posterOverlay = document.getElementById("poster-overlay");

        if (!featureVideo || !video || !videoSource) return;

        const isMobile = window.innerWidth < 768;
        const chosen = isMobile
            ? featureVideo.dataset.videoMobile
            : featureVideo.dataset.videoDesktop;
        if (chosen) videoSource.src = chosen;
        video.load();

        video.addEventListener("loadeddata", () => {
            if (posterOverlay) {
                posterOverlay.style.transition = "opacity 0.5s";
                posterOverlay.style.opacity = "0";
                setTimeout(() => posterOverlay.remove(), 500);
            }
        });
    }

    initHeroVideo();
    // Re-run after view transitions: the new page re-renders #poster-overlay
    // (z-30, fullscreen) and without re-running this, it never fades out and
    // blocks clicks on the navbar.
    document.addEventListener("astro:after-swap", initHeroVideo);
</script>

<style>
    /* Fade-in animation for content */
    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: scale(0.7);
        }
        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    .animate-fadeIn {
        animation: fadeIn 1s cubic-bezier(0.4, 0, 0.2, 1) both;
    }
</style>
