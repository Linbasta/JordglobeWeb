---
import { Image } from "astro:assets";
import TintedAvatar from "./TintedAvatar.astro";
import { Icon } from "astro-icon/components";

// data
import { type TestimonialItem } from "@config/types/configDataTypes";

interface Props extends TestimonialItem {
	rest?: any;
	class?: string; // any additional classes
}

const { class: className, avatar, name, title, testimonial, avatarTintColor, ...rest } = Astro.props as Props;
---

<div
	class="flex h-full flex-col rounded-xl border bg-testimonial-card p-3 transition-colors md:p-4 dark:border-base-800 dark:bg-base-900 dark:text-base-100 dark:hover:border-base-700"
	class:list={className}
	{...rest}>
	<div class="flex items-center gap-4">
		<div class="relative inline-block w-[75px] h-[75px]">
			{avatarTintColor ? (
				<TintedAvatar src={avatar.src} alt={name} tintColor={avatarTintColor} />
			) : (
				<Image 
					src={avatar} 
					alt={name} 
					class="rounded-full object-cover w-full h-full"
				/>
			)}
		</div>
		<div>
			<p class="font-semibold">{name}</p>
			<p class="description text-sm">{title}</p>
		</div>
	</div>
	<p class="mt-6 text-sm md:text-base">"{testimonial}"</p>
</div>
