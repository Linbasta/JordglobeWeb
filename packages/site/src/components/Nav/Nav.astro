---
import NavLink from "@components/Nav/NavLink.astro";
import NavDropdownToggle from "./NavDropdown/NavDropdownToggle.astro";
import MegaMenuDropdownToggle from "@components/Nav/NavDropdown/MegaMenuDropdownToggle.astro";
import MobileNav from "@components/Nav/MobileNav/MobileNav.astro";
import SiteLogo from "@components/SiteLogo/SiteLogo.astro";
import Button from "@components/Button/Button.astro";
import LanguageSelect from "@components/LanguageSelect/LanguageSelect.astro";
import ThemeToggle from "@components/ThemeToggle/ThemeToggle.astro";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { getTranslatedData, useTranslations } from "@js/translationUtils";

// data
const currLocale = getLocaleFromUrl(Astro.url);
const navData = getTranslatedData("navData", currLocale);
const t = useTranslations(currLocale);
import { locales, defaultLocale } from "@config/siteSettings.json";
import { routeTranslations } from "@config/translationData.json";

const aboutSlug = routeTranslations[currLocale].aboutKey;
const aboutPath = currLocale === defaultLocale ? `/${aboutSlug}` : `/${currLocale}/${aboutSlug}`;
const pathEnd = Astro.url.pathname.replace(/\/$/, "").split("/").pop();
const isAboutPage = pathEnd === aboutSlug;
const localeHome = currLocale === defaultLocale ? "/" : `/${currLocale}/`;
// console.log(JSON.stringify(navData, null, 2));
---

<div
	id="nav__container"
	class="navbar--initial fixed top-0 left-0 z-30 flex w-full flex-col transition-all duration-300"
	transition:name={`nav`}
>
	<div class="mx-auto flex w-full">
		<div class="site-container flex h-14 w-full items-center">
			<header class="relative flex w-full items-center gap-2">
				<!-- home button / image -->
				<div class="flex flex-auto justify-start">
					<SiteLogo />
				</div>

				<!-- <div class="flex flex-auto justify-center">
          
        </div> -->

				<!-- desktop nav menu -->
				<div class="flex flex-auto justify-end">
					<nav class="nav-font hidden items-center md:flex">
						<ul class="flex h-fit items-center px-4">
							{
								// if dropdown exists, setup the dropdown, otherwise it is just a link
								navData.map((navItem) =>
									"dropdown" in navItem ? (
										// non-mobile dropdown menu
										<>
											{/* <NavDropdown navItem={navItem} /> */}
											<NavDropdownToggle navItem={navItem} />
										</>
									) : "megaMenuColumns" in navItem ? (
										<MegaMenuDropdownToggle {navItem} />
									) : (
										// normal nav link
										<NavLink {navItem} />
									),
								)
							}
						</ul>
					</nav>

					<!-- <ThemeToggle class="my-auto -ml-4 hidden md:block" /> -->

					<!-- spacer if desired -->
					<!-- <div class="mr-2 ml-4 my-2 border-l border-base-300 dark:border-base-700">
          </div> -->

					<!-- <Button
                        variant="ghost"
                        class="nav__link--base relative mr-2 hidden items-center gap-1.5 rounded-sm px-4 py-2 transition duration-200 md:flex"
                        href="/login"
                    >
                        Login
                    </Button> -->

					<Button
						variant="secondary"
						class="my-auto mr-4 hidden h-10 px-4 md:flex md:items-center !border-transparent !bg-[#BCF244] hover:!bg-[#0DC400] !text-[#00482E] hover:!text-white"
						href="/downloadfromsite"
					>
						{t("nav_download")}
					</Button>
					<Button
						variant="secondary"
						class="my-auto mr-4 hidden h-10 px-4 md:flex md:items-center !border-transparent !bg-[#000E69] hover:!bg-[#014BD0] !text-white"
						href={isAboutPage ? localeHome : aboutPath}
					>
						{isAboutPage ? t("nav_games") : t("nav_about")}
					</Button>
					{/* Hide on mobile — the hamburger drawer carries its own Discord button */}
					<Button
						variant="secondary"
						class="my-auto mr-4 hidden h-10 px-4 md:flex md:items-center !border-transparent !bg-[#000E69] hover:!bg-[#014BD0] !text-white"
						href="https://discord.gg/xQkdK2vkfF"
						aria-label="Discord"
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="0 0 126.644 96"
							fill="currentColor"
							aria-hidden="true"
							class="h-5 w-auto"
						>
							<path d="M81.15,0c-1.2376,2.1973-2.3489,4.4704-3.3591,6.794-9.5975-1.4396-19.3718-1.4396-28.9945,0-.985-2.3236-2.1216-4.5967-3.3591-6.794-9.0166,1.5407-17.8059,4.2431-26.1405,8.0568C2.779,32.5304-1.6914,56.3725.5312,79.8863c9.6732,7.1476,20.5083,12.603,32.0505,16.0884,2.6014-3.4854,4.8998-7.1981,6.8698-11.0623-3.738-1.3891-7.3497-3.1318-10.8098-5.1523.9092-.6567,1.7932-1.3386,2.6519-1.9953,20.281,9.547,43.7696,9.547,64.0758,0,.8587.7072,1.7427,1.3891,2.6519,1.9953-3.4601,2.0457-7.0718,3.7632-10.835,5.1776,1.97,3.8642,4.2683,7.5769,6.8698,11.0623,11.5419-3.4854,22.3769-8.9156,32.0509-16.0631,2.626-27.2771-4.496-50.9172-18.817-71.8548C98.9811,4.2684,90.1918,1.5659,81.1752.0505l-.0252-.0505ZM42.2802,65.4144c-6.2383,0-11.4159-5.6575-11.4159-12.6535s4.9755-12.6788,11.3907-12.6788,11.5169,5.708,11.4159,12.6788c-.101,6.9708-5.026,12.6535-11.3907,12.6535ZM84.3576,65.4144c-6.2637,0-11.3907-5.6575-11.3907-12.6535s4.9755-12.6788,11.3907-12.6788,11.4917,5.708,11.3906,12.6788c-.101,6.9708-5.026,12.6535-11.3906,12.6535Z" />
						</svg>
					</Button>

					{locales.length > 1 && <LanguageSelect class="hidden md:block" />}

					<!-- mobile nav menu, only load on small screens where it is visible -->
					<div class="md:hidden">
						<MobileNav />
					</div>
				</div>
			</header>
		</div>
	</div>
</div>

<style>
	@import "tailwindcss/theme" theme(reference);
	@import "@/styles/tailwind-theme.css" theme(reference);

	.navbar--scrolled {
		@apply border-b-border bg-background;
	}

	.navbar--initial {
		@apply border-b-transparent bg-transparent py-2;
	}
</style>

<script>
	let navbar: HTMLElement | null;
	let scrollListenerAttached = false;

	function scrollHandler() {
		if (navbar) {
			if (window.scrollY > 50) {
				// if we have scrolled down the page a bit, add a frosted-glass look to the navbar
				navbar.classList.add("navbar--scrolled");
				navbar.classList.remove("navbar--initial");
			} else {
				navbar.classList.add("navbar--initial");
				navbar.classList.remove("navbar--scrolled");
			}
		}
	}

	function initNav() {
		navbar = document.getElementById("nav__container");

		// Always detach any existing listener — view transitions reuse this script,
		// so without this we'd leak listeners across navigations and the listener
		// from a previous page would keep mutating the new page's navbar.
		if (scrollListenerAttached) {
			window.removeEventListener("scroll", scrollHandler);
			scrollListenerAttached = false;
		}

		// Pages that opt out of the scroll-fade mark the body with `static-nav`.
		// Force the navbar back to its initial transparent state and don't attach.
		if (document.body.classList.contains("static-nav")) {
			if (navbar) {
				navbar.classList.add("navbar--initial");
				navbar.classList.remove("navbar--scrolled");
			}
			return;
		}

		window.addEventListener("scroll", scrollHandler, { passive: true });
		scrollListenerAttached = true;
		// Sync to current scroll position so we don't render in the wrong state
		// for a frame after navigating to a non-static page.
		scrollHandler();
	}

	// runs on initial page load
	initNav();

	// runs on view transitions navigation. Not needed if item has "transition:persist"
	document.addEventListener("astro:after-swap", initNav);
</script>
