---
import { getRelativeLocaleUrl } from "astro:i18n";

// components
import FooterLink from "@components/Footer/FooterLink.astro";
import SiteLogo from "@components/SiteLogo/SiteLogo.astro";
import Button from "@components/Button/Button.astro";
import SocialIcon from "@components/SocialIcon/SocialIcon.astro";

// utils
import { getLocaleFromUrl } from "@js/localeUtils";
import { getTranslatedData } from "@js/translationUtils";

// data
const currLocale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", currLocale);

const today = new Date();
---

<footer class="overflow-clip pt-24 pb-16">
	<div id="footer" class="site-container">
		<!-- Wrap the top border section in a uniform container -->
		<div class="mx-auto max-w-7xl px-4 border-b pb-20">
			<div class="flex flex-wrap">
				<div class="w-full p-2 md:w-1/2">
					<div class="max-w-xs">
						<SiteLogo />
						<p class="mt-11 tracking-tight">
							{siteData.description}
						</p>
					</div>
				</div>
				<div class="w-full p-2 md:w-1/2">
					<div class="flex flex-wrap justify-end gap-x-10">
						<FooterLink href={getRelativeLocaleUrl(currLocale, "/")}>Games</FooterLink>
						<FooterLink href={getRelativeLocaleUrl(currLocale, "/about")}>About</FooterLink>
						<FooterLink href={getRelativeLocaleUrl(currLocale, "/blog")}>Blog</FooterLink>
						<FooterLink href={getRelativeLocaleUrl(currLocale, "/gdpr")}>Privacy</FooterLink>
					</div>
				</div>
			</div>
		</div>
		<!-- Wrap the bottom section in the same container -->
		<div class="mx-auto max-w-7xl px-4 py-6">
			<div class="-m-4 flex flex-wrap items-center justify-between">
				<div class="w-auto p-4">
					<p class="tracking-tight">
						&copy; {today.getFullYear()}
						{" "}{siteData.name}. All rights reserved.
					</p>
				</div>
				<div class="w-auto p-4">
					<!-- Socials -->
					<div class="flex flex-col">
						<div class="flex gap-5">
							<SocialIcon
								href="https://twitter.com/ollelandin"
								icon="tabler/brand-x"
								social="twitter (x)"
							/>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</footer>
