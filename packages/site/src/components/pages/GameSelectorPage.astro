---
import BaseLayout from "@layouts/BaseLayout.astro";
import { Image } from "astro:assets";

import DownloadBento from "@components/DownloadBento.astro";
import { getLocaleFromUrl } from "@js/localeUtils";
import { getTranslatedData } from "@js/translationUtils";
import { videoGameSchema } from "@js/jsonLD";

import euroMusicImage from "@images/front/euro-music-quiz-thumbnail.png";
import euroWinnersImage from "@images/front/euro-winners-2000s.png";
import gameQuizImage from "@images/front/game-quiz.png";
import usStatesImage from "@images/front/united-states-of-america-states.png";
import worldCountriesImage from "@images/front/the-world-countries.png";
import worldFlagsImage from "@images/front/the-world-flags.png";
import worldCapitalsImage from "@images/front/the-world-capitals.png";
import posterImage from "@images/front/first-frame.jpg";

const imageMap: Record<string, ImageMetadata> = {
    "euro-music-quiz": euroMusicImage,
    "euro-winners-2000s": euroWinnersImage,
    "game-quiz": gameQuizImage,
    "united-states-of-america-states": usStatesImage,
    "the-world-countries": worldCountriesImage,
    "the-world-flags": worldFlagsImage,
    "the-world-capitals": worldCapitalsImage,
};

const locale = getLocaleFromUrl(Astro.url);
const siteData = getTranslatedData("siteData", locale);
const gamesData = getTranslatedData("gamesData", locale);

type GameMeta = (typeof gamesData.games)[number] & { image: ImageMetadata };

const gamesById = new Map<string, GameMeta>(
    gamesData.games.map((game) => [
        game.id,
        { ...game, image: imageMap[game.id] },
    ]),
);

const topics = (gamesData.topics ?? []).map((topic) => ({
    title: topic.title,
    games: topic.gameIds
        .map((id) => gamesById.get(id))
        .filter((g): g is GameMeta => Boolean(g)),
}));

const gameSchemas = Array.from(gamesById.values()).map((game) =>
    videoGameSchema({
        name: game.seoTitle ?? game.title,
        description: game.seoDescription ?? game.description,
        url: `${import.meta.env.SITE}${game.link}`,
        image: `${import.meta.env.SITE}${game.image.src}`,
        genre: game.genre,
    }),
);
---

<BaseLayout
    title={`${gamesData.pageTitle} | ${siteData.title}`}
    description={gamesData.pageSubtitle}
    staticNav={true}
>
    {gameSchemas.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <section class="selector">
        <video
            class="bg-video"
            autoplay
            loop
            muted
            playsinline
            poster={posterImage.src}
            data-video-desktop="/assets/globe.m4v"
            data-video-mobile="/assets/globe-mobile.m4v"
        >
            <source src="/assets/globe.m4v" type="video/mp4" />
        </video>
        <div class="overlay"></div>

        <div class="content">
            <header class="page-header">
                <h1>{gamesData.pageTitle}</h1>
            </header>

            <div class="layout">
                {topics.map((topic) => (
                    <Fragment>
                        <h2 class="topic-title">{topic.title}</h2>
                        <div class="row-wrap">
                            <div class="row">
                                {topic.games.map((game) => (
                                    <a href={game.link} class="game-card" draggable="false" data-astro-reload>
                                        <div class="thumb-stack">
                                            <div class="thumb-base"></div>
                                            <div class="thumb">
                                                <Image
                                                    src={game.image}
                                                    alt={game.title}
                                                    width={800}
                                                    height={450}
                                                    loading="lazy"
                                                    draggable={false}
                                                />
                                                {game.cardLabel && (
                                                    <div class="thumb-label">
                                                        <span class="thumb-label-title">{game.cardLabel.title}</span>
                                                        <span class="thumb-label-subtitle">{game.cardLabel.subtitle}</span>
                                                    </div>
                                                )}
                                            </div>
                                            <div class="card-spinner"></div>
                                        </div>
                                    </a>
                                ))}
                            </div>
                            <button class="nav-btn nav-prev" type="button" aria-label="Scroll left">
                                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <path d="M15 18 9 12l6-6"></path>
                                </svg>
                            </button>
                            <button class="nav-btn nav-next" type="button" aria-label="Scroll right">
                                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <path d="m9 6 6 6-6 6"></path>
                                </svg>
                            </button>
                        </div>
                    </Fragment>
                ))}

                <div class="bento-col">
                    <DownloadBento />
                </div>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    .selector {
        position: relative;
        min-height: 100vh;
        overflow: hidden;
    }

    .bg-video {
        position: fixed;
        inset: 0;
        z-index: 0;
        object-fit: cover;
        width: 100%;
        height: 100%;
    }

    .overlay {
        position: fixed;
        inset: 0;
        z-index: 1;
        background: rgba(0, 31, 102, 0.85);
        pointer-events: none;
    }

    .content {
        position: relative;
        z-index: 2;
        max-width: 1280px;
        margin: 0 auto;
        padding: 96px 16px 64px;
        color: #fff;
    }

    @media (min-width: 1600px) {
        .content {
            max-width: 1600px;
        }
    }

    .page-header {
        text-align: center;
        margin-bottom: 56px;
    }

    .page-header h1 {
        font-size: clamp(28px, 4vw, 44px);
        font-weight: 800;
        letter-spacing: 6px;
        text-transform: uppercase;
        margin: 0 0 12px;
    }

    .layout {
        --lift-room: 12px;
        --topic-gap: 48px;
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        column-gap: 16px;
        align-items: start;
    }

    .bento-col {
        display: none;
    }

    /* Mobile: titles and row-wraps stack centered with the same constraint
       the wrapper used to enforce. */
    .topic-title,
    .row-wrap {
        max-width: 800px;
        margin-left: auto;
        margin-right: auto;
    }

    /* Replaces the old `.topic { margin-bottom: 48px }` now that topics
       aren't wrapped — gap between row-wrap and the next topic title. */
    .row-wrap + .topic-title {
        margin-top: 48px;
    }

    @media (min-width: 1024px) {
        /* Explicit row tracks: each topic is `lift-room | thumbs | lift-room`
           with the named lines `thumb-N-top` / `thumb-N-bot` marking the
           visible thumbnail edges. The bento spans `thumb-1-top → thumb-2-bot`
           directly, no compensation. `--lift-room` is also `.row`'s vertical
           padding, so the .row's content lands inside the named "thumbs"
           track by construction. */
        .layout {
            grid-template-columns: minmax(0, 1fr) 380px;
            grid-template-rows:
                auto                                /* 1: title 1            */
                var(--lift-room)                    /* 2: row 1 top lift     */
                [thumb-1-top] auto [thumb-1-bot]    /* 3: row 1 thumbnails   */
                var(--lift-room)                    /* 4: row 1 bottom lift  */
                var(--topic-gap)                    /* 5: gap between topics */
                auto                                /* 6: title 2            */
                var(--lift-room)                    /* 7: row 2 top lift     */
                [thumb-2-top] auto [thumb-2-bot]    /* 8: row 2 thumbnails   */
                var(--lift-room);                   /* 9: row 2 bottom lift  */
        }
        .topic-title,
        .row-wrap {
            max-width: none;
            margin-left: 0;
            margin-right: 0;
        }
        .topic-title:nth-of-type(1) { grid-row: 1; grid-column: 1; }
        .row-wrap:nth-of-type(1)    { grid-row: 2 / 5; grid-column: 1; }
        .topic-title:nth-of-type(2) { grid-row: 6; grid-column: 1; }
        .row-wrap:nth-of-type(2)    { grid-row: 7 / 10; grid-column: 1; }

        /* Topic gap is its own track now; cancel the mobile sibling margin. */
        .row-wrap + .topic-title {
            margin-top: 0;
        }

        /* Single-cell inner grid stretches the .download-bento child to the
           cell automatically (no `height: 100%` chain needed). `min-height: 0`
           + `overflow: hidden` are critical: without them the bento's
           natural content height (~430px) is bigger than the area (~350px),
           and grid auto-tracks would *grow* row 3, 6, 8 to fit the bento,
           which silently pushes `[thumb-2-bot]` past the actual thumbnail
           bottom. With min-height: 0, the bento contributes 0 to track
           sizing, so the thumb rows are sized purely by the column-1
           row-wraps, and the bento clips to whatever fits. */
        .bento-col {
            display: grid;
            grid-column: 2;
            grid-row: thumb-1-top / thumb-2-bot;
            align-self: stretch;
            min-height: 0;
            overflow: hidden;
        }
        .bento-col > :global(.download-bento) {
            min-height: 0;
            justify-content: space-between;
        }
        /* Phones at full bento width (square ⇒ tall) and negative-margined
           down so its bottom 30% overlaps the app-name and store-row. The
           wrap is taken out of layered flow (z-index 0) so the text reads
           above it; pointer-events: none keeps the overlapping area
           clickable for the badges/qr underneath. */
        .bento-col > :global(.download-bento) > :global(.phones-wrap) {
            flex: 0 0 auto;
            width: 100%;
            display: block;
            margin-bottom: -10%;     /* of bento width = ~10% of image height */
            position: relative;
            z-index: 0;
            pointer-events: none;
            overflow: visible;
        }
        .bento-col > :global(.download-bento) > :global(.phones-wrap) :global(img) {
            width: 100%;
            max-width: 100%;
            height: auto;
            object-fit: contain;
            display: block;
        }
        /* Text + badges/qr layer above the overlapping phones bottom. */
        .bento-col > :global(.download-bento) > :global(.app-name),
        .bento-col > :global(.download-bento) > :global(.store-row) {
            position: relative;
            z-index: 1;
        }
    }

    @media (min-width: 1600px) {
        .layout {
            grid-template-columns: minmax(0, 1fr) 400px;
        }
    }

    .topic-title {
        font-size: clamp(20px, 2.5vw, 28px);
        font-weight: 700;
        margin-top: 0;
        margin-bottom: 16px;
        color: #fff;
    }

    .row-wrap {
        position: relative;
    }

    .row-wrap::before,
    .row-wrap::after {
        content: "";
        position: absolute;
        top: 0;
        bottom: 0;
        width: 64px;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.2s ease;
        z-index: 2;
    }

    .row-wrap::before {
        left: 0;
        background: linear-gradient(
            to right,
            rgba(8, 18, 50, 0.95),
            rgba(8, 18, 50, 0)
        );
    }

    .row-wrap::after {
        right: 0;
        background: linear-gradient(
            to left,
            rgba(8, 18, 50, 0.95),
            rgba(8, 18, 50, 0)
        );
    }

    .row-wrap[data-can-prev="true"]::before {
        opacity: 1;
    }

    .row-wrap[data-can-next="true"]::after {
        opacity: 1;
    }

    .row {
        display: flex;
        gap: 12px;
        overflow-x: auto;
        scroll-snap-type: x proximity;
        /* `--lift-room` is the vertical breathing room the hover lift needs
           (overflow-x: auto forces overflow-y to clip). The same variable
           drives the dedicated grid tracks above/below the thumbnails so the
           bento can span thumbnail edges without compensation. */
        padding: var(--lift-room) 0;
        scrollbar-width: none;
        -ms-overflow-style: none;
    }

    .row::-webkit-scrollbar {
        display: none;
    }

    .row.is-dragging {
        cursor: grabbing;
        user-select: none;
    }

    /* Free-form scroll while dragging or while a JS snap animation is
       running. Without this, removing .is-dragging on release lets the CSS
       snap engine kick in and instantly relocate the row to the nearest
       snap point, killing the easing animation before its first frame. */
    .row.is-dragging,
    .row.is-snapping {
        scroll-snap-type: none;
    }

    .row.is-dragging * {
        cursor: grabbing !important;
    }

    .nav-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 40px;
        height: 40px;
        border: none;
        border-radius: 50%;
        background: rgba(8, 18, 50, 0.85);
        color: #fff;
        cursor: pointer;
        display: grid;
        place-items: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s ease, background-color 0.15s ease,
            transform 0.15s ease;
        z-index: 3;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.45);
    }

    .nav-btn:hover {
        background: rgba(8, 18, 50, 0.95);
        transform: translateY(-50%) scale(1.06);
    }

    .nav-prev {
        left: 8px;
    }

    .nav-next {
        right: 8px;
    }

    .row-wrap[data-can-prev="true"]:hover .nav-prev,
    .row-wrap[data-can-prev="true"].is-dragging .nav-prev {
        opacity: 1;
        pointer-events: auto;
    }

    .row-wrap[data-can-next="true"]:hover .nav-next,
    .row-wrap[data-can-next="true"].is-dragging .nav-next {
        opacity: 1;
        pointer-events: auto;
    }

    @media (hover: none) {
        .nav-btn {
            display: none;
        }
    }

    .game-card {
        flex: 0 0 280px;
        scroll-snap-align: start;
        text-decoration: none;
        color: inherit;
    }

    /* At ≥1600 vp the topics-col is 1152 px, which fits 4 × 280 + 3 × 12 =
       1156 px only 4 px short of cleanly rejecting a 4th card. Bumping the
       card to 376 makes 3 × 376 + 2 × 12 = 1152 px exact: 3 cards fill the
       row, 4 are 384 px too wide so they can't appear. */
    @media (min-width: 1600px) {
        .game-card {
            flex: 0 0 376px;
        }
    }

    .thumb-stack {
        position: relative;
        aspect-ratio: 16 / 9;
    }

    .thumb-base {
        position: absolute;
        inset: 0;
        background: #3b82f6;
        border-radius: 10px;
    }

    .thumb {
        position: absolute;
        inset: 0;
        border-radius: 10px;
        overflow: hidden;
        background: #000;
        transition: transform 0.18s ease;
    }

    .game-card:hover .thumb {
        transform: translateY(-6px);
    }

    .game-card.is-loading .thumb {
        transform: none;
        opacity: 0.6;
    }

    .game-card.is-loading .thumb::after {
        content: "";
        position: absolute;
        inset: 0;
        display: flex;
        z-index: 2;
        background: rgba(0, 0, 0, 0.3);
    }

    .game-card.is-loading .card-spinner {
        display: block;
    }

    .card-spinner {
        display: none;
        position: absolute;
        inset: 0;
        z-index: 3;
        pointer-events: none;
    }

    .card-spinner::after {
        content: "";
        position: absolute;
        top: 50%;
        left: 50%;
        width: 36px;
        height: 36px;
        margin: -18px 0 0 -18px;
        border: 3px solid rgba(255, 255, 255, 0.3);
        border-top-color: #fff;
        border-radius: 50%;
        animation: card-spin 0.7s linear infinite;
    }

    @keyframes card-spin {
        to { transform: rotate(360deg); }
    }

    .thumb :global(img) {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .thumb-label {
        position: absolute;
        left: 0;
        bottom: 0;
        padding: 10px 14px;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 2px;
        pointer-events: none;
        line-height: 1;
    }

    .thumb-label-title {
        font-family: "Bowlby One SC", system-ui, sans-serif;
        font-weight: 400;
        font-size: 20px;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        color: #BCF244;
        -webkit-text-stroke: 1.5px #14532d;
        text-shadow: 2px 2px 0 rgba(0, 0, 0, 0.55);
        /* paint-order draws stroke under fill so the text core stays bright */
        paint-order: stroke fill;
    }

    .thumb-label-subtitle {
        font-family: "InterVariable", system-ui, sans-serif;
        font-weight: 600;
        font-size: 14px;
        color: #ffffff;
        text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.5);
    }

    @media (max-width: 640px) {
        .content {
            padding: 80px 16px 48px;
        }

        .page-header {
            margin-bottom: 32px;
        }

        .page-header h1 {
            letter-spacing: 3px;
        }

        .topic {
            margin-bottom: 28px;
        }

        .topic-title {
            margin: 0 0 12px;
        }

        .game-card {
            flex: 0 0 60vw;
            max-width: 220px;
        }

        .row {
            padding: 12px 16px;
            scroll-snap-type: x proximity;
            scroll-padding-left: 16px;
        }
    }
</style>

<script>
    // Show a loading spinner on the clicked game card so the user gets
    // immediate feedback while the game page loads.
    document.querySelectorAll<HTMLAnchorElement>(".game-card").forEach((card) => {
        card.addEventListener("click", () => {
            card.classList.add("is-loading");
        });
    });

    // Clear the loading state if the user navigates back (bfcache).
    window.addEventListener("pageshow", (e) => {
        if (e.persisted) {
            document.querySelectorAll(".game-card.is-loading").forEach((c) => {
                c.classList.remove("is-loading");
            });
        }
    });
</script>

<script>
    // Native loop on the <video> element handles the wrap; this script just
    // picks the right source for the viewport and pins playbackRate.
    const video = document.querySelector<HTMLVideoElement>(".bg-video");
    if (video) {
        // Pick the mobile-encoded source on narrow viewports to save bandwidth and
        // decode work. Mirrors the pattern used in HeroVideo.astro.
        const source = video.querySelector<HTMLSourceElement>("source");
        const desktopSrc = video.dataset.videoDesktop;
        const mobileSrc = video.dataset.videoMobile;
        const chosen = window.innerWidth < 768 ? mobileSrc : desktopSrc;
        if (source && chosen && source.src !== chosen) {
            source.src = chosen;
            video.load();
        }

        const PLAYBACK_RATE = 0.8;
        video.playbackRate = PLAYBACK_RATE;
        // Some browsers reset playbackRate on source/loadedmetadata, so re-pin.
        video.addEventListener("loadedmetadata", () => {
            video.playbackRate = PLAYBACK_RATE;
        });
        video.addEventListener("play", () => {
            video.playbackRate = PLAYBACK_RATE;
        });
    }

    // Debug: 'c' toggles the dim overlay so we can see the raw bg video.
    const overlay = document.querySelector<HTMLElement>(".overlay");
    document.addEventListener("keydown", (e) => {
        if (e.key !== "c") return;
        const tag = (e.target as HTMLElement | null)?.tagName;
        if (tag === "INPUT" || tag === "TEXTAREA") return;
        if (overlay) {
            overlay.style.display = overlay.style.display === "none" ? "" : "none";
        }
    });
</script>

<script>
    // 280px card + 12px gap = one card step.
    const SCROLL_STEP = 292;
    const DRAG_THRESHOLD = 5;

    // Custom rAF-driven scroll animation with easeOutQuint. The .is-snapping
    // class on the row keeps CSS scroll-snap-type: none for the animation's
    // lifetime — without that, the browser snaps the row instantly the
    // moment .is-dragging is removed and the easing never plays.
    function animateScroll(el: HTMLElement, target: number) {
        const handle = (el as any).__snapAnim as number | undefined;
        if (handle !== undefined) cancelAnimationFrame(handle);
        const start = el.scrollLeft;
        const delta = target - start;
        if (Math.abs(delta) < 0.5) {
            el.classList.remove("is-snapping");
            return;
        }
        el.classList.add("is-snapping");
        // Distance-scaled: tiny snaps stay quick, full card jumps get
        // enough time to feel deliberate.
        const duration = Math.min(800, 420 + Math.abs(delta) * 0.7);
        const t0 = performance.now();
        const easeOutQuint = (t: number) => 1 - Math.pow(1 - t, 5);
        const tick = (now: number) => {
            const t = Math.min(1, (now - t0) / duration);
            el.scrollLeft = start + delta * easeOutQuint(t);
            if (t < 1) {
                (el as any).__snapAnim = requestAnimationFrame(tick);
            } else {
                (el as any).__snapAnim = undefined;
                el.classList.remove("is-snapping");
            }
        };
        (el as any).__snapAnim = requestAnimationFrame(tick);
    }

    function nearestCardOffset(row: HTMLElement, target: number): number {
        const cards = row.querySelectorAll<HTMLElement>(".game-card");
        let nearest = target;
        let minDist = Infinity;
        cards.forEach((card) => {
            const dist = Math.abs(card.offsetLeft - target);
            if (dist < minDist) {
                minDist = dist;
                nearest = card.offsetLeft;
            }
        });
        return nearest;
    }

    document.querySelectorAll<HTMLElement>(".row-wrap").forEach((wrap) => {
        const row = wrap.querySelector<HTMLElement>(".row");
        const prevBtn = wrap.querySelector<HTMLButtonElement>(".nav-prev");
        const nextBtn = wrap.querySelector<HTMLButtonElement>(".nav-next");
        if (!row || !prevBtn || !nextBtn) return;

        function updateBoundaries() {
            if (!row) return;
            const canPrev = row.scrollLeft > 1;
            const canNext =
                row.scrollLeft + row.clientWidth < row.scrollWidth - 1;
            wrap.dataset.canPrev = canPrev ? "true" : "false";
            wrap.dataset.canNext = canNext ? "true" : "false";
        }
        updateBoundaries();
        row.addEventListener("scroll", updateBoundaries, { passive: true });
        window.addEventListener("resize", updateBoundaries);

        prevBtn.addEventListener("click", () => {
            animateScroll(row, nearestCardOffset(row, row.scrollLeft - SCROLL_STEP));
        });
        nextBtn.addEventListener("click", () => {
            animateScroll(row, nearestCardOffset(row, row.scrollLeft + SCROLL_STEP));
        });

        // Drag-to-scroll, mouse only — touch keeps native scrolling.
        let isDown = false;
        let isDragging = false;
        let startX = 0;
        let startScrollLeft = 0;

        let activePointerId: number | null = null;

        row.addEventListener("pointerdown", (e: PointerEvent) => {
            if (e.pointerType !== "mouse" || e.button !== 0) return;
            // Cancel any in-flight settle animation if the user grabs again.
            const handle = (row as any).__snapAnim as number | undefined;
            if (handle !== undefined) {
                cancelAnimationFrame(handle);
                (row as any).__snapAnim = undefined;
                row.classList.remove("is-snapping");
            }
            isDown = true;
            isDragging = false;
            startX = e.clientX;
            startScrollLeft = row.scrollLeft;
            activePointerId = e.pointerId;
            // Note: do NOT setPointerCapture here. Capturing on a plain click
            // redirects the matching pointerup to the row, which causes the
            // browser to fire `click` on the row instead of the descendant
            // <a>, so card navigation silently breaks. Capture only kicks in
            // once an actual drag is detected (see pointermove).
        });

        row.addEventListener("pointermove", (e: PointerEvent) => {
            if (!isDown) return;
            const dx = e.clientX - startX;
            if (!isDragging && Math.abs(dx) > DRAG_THRESHOLD) {
                isDragging = true;
                row.classList.add("is-dragging");
                wrap.classList.add("is-dragging");
                try {
                    row.setPointerCapture(e.pointerId);
                } catch {
                    /* capture may fail if pointer already released */
                }
            }
            if (isDragging) {
                row.scrollLeft = startScrollLeft - dx;
            }
        });

        function endDrag(e: PointerEvent) {
            if (!isDown) return;
            isDown = false;
            try {
                if (activePointerId !== null) {
                    row?.releasePointerCapture(activePointerId);
                }
            } catch {
                /* pointer may already be released or never captured */
            }
            activePointerId = null;
            if (isDragging) {
                // Suppress the synthetic click that would otherwise navigate
                // when a drag ends on top of a card link.
                const suppress = (ev: Event) => {
                    ev.preventDefault();
                    ev.stopPropagation();
                    row?.removeEventListener("click", suppress, true);
                };
                row?.addEventListener("click", suppress, true);
                if (row) {
                    // Order matters: add is-snapping BEFORE removing
                    // is-dragging so scroll-snap-type stays `none` across
                    // the transition. Otherwise the browser sees snap go
                    // none → proximity with the row mid-card, snaps it
                    // instantly, and our animation reads scrollLeft already
                    // at the snap point (delta ≈ 0, no animation runs).
                    row.classList.add("is-snapping");
                    row.classList.remove("is-dragging");
                    wrap.classList.remove("is-dragging");
                    animateScroll(row, nearestCardOffset(row, row.scrollLeft));
                } else {
                    wrap.classList.remove("is-dragging");
                }
            }
            isDragging = false;
        }

        row.addEventListener("pointerup", endDrag);
        row.addEventListener("pointercancel", endDrag);
    });
</script>
