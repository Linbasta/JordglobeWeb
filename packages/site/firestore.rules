rules_version = '2';
service cloud.firestore {
    match /databases/{database}/documents {

        // Append-only PB log. Client writes only when the play is that user's
        // personal best (gated via localStorage in the app); rule enforces
        // payload shape and bounds. Reads are server-side only — the scheduled
        // updateDailyLeaderboards Cloud Function uses the admin SDK.
        match /submissions/{docId} {
            allow read: if false;
            allow create: if request.auth != null
                && request.resource.data.keys().hasOnly(
                    ['quiz_id', 'score', 'total', 'elapsed_ms', 'created_at'])
                && request.resource.data.quiz_id is string
                && request.resource.data.score is int
                && request.resource.data.total is int
                && request.resource.data.elapsed_ms is int
                && request.resource.data.created_at is timestamp
                && request.resource.data.score >= 0
                && request.resource.data.score <= request.resource.data.total
                && request.resource.data.elapsed_ms >= 0;
            allow update, delete: if false;
        }

        // Aggregated daily top-N. Public read for leaderboard UI. Only the
        // scheduled Cloud Function writes here (admin SDK bypasses rules).
        match /leaderboards/{quizId} {
            allow read: if true;
            allow write: if false;
        }
    }
}
