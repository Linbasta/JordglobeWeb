{
    "hosting": [{
        "target": "prod",
        "public": "dist",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "redirects": [
            {
                "source": "/trivia",
                "destination": "/games",
                "type": 301
            },
            {
                "source": "/sv/trivia",
                "destination": "/sv/games",
                "type": 301
            }
        ],
        "rewrites": [
            {
                "source": "/duel",
                "destination": "/duel/index.html"
            },
            {
                "source": "/games/euro-music-quiz/sv{,/**}",
                "destination": "/games/euro-music-quiz/sv/index.html"
            },
            {
                "source": "/games/euro-music-quiz/**",
                "destination": "/games/euro-music-quiz/index.html"
            },
            {
                "source": "/euro-music-quiz{,/**}",
                "destination": "/games/euro-music-quiz/index.html"
            },
            {
                "source": "**",
                "destination": "/index.html"
            }
        ],
        "headers": [
            {
                "source": "/.well-known/apple-app-site-association",
                "headers": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ]
            },
            {
                "source": "/.well-known/testfile",
                "headers": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ]
            },
            {
                "source": "/_astro/**",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "public, max-age=31536000, immutable"
                    }
                ]
            },
            {
                "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|js|css|eot|otf|ttf|ttc|woff|woff2|font.css)",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "public, max-age=31536000, immutable"
                    }
                ]
            }
        ]
    },
    {
        "target": "stage",
        "public": "dist",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "redirects": [
            {
                "source": "/trivia",
                "destination": "/games",
                "type": 301
            },
            {
                "source": "/sv/trivia",
                "destination": "/sv/games",
                "type": 301
            }
        ],
        "rewrites": [
            {
                "source": "/duel",
                "destination": "/duel/index.html"
            },
            {
                "source": "/games/euro-music-quiz/sv{,/**}",
                "destination": "/games/euro-music-quiz/sv/index.html"
            },
            {
                "source": "/games/euro-music-quiz/**",
                "destination": "/games/euro-music-quiz/index.html"
            },
            {
                "source": "/euro-music-quiz{,/**}",
                "destination": "/games/euro-music-quiz/index.html"
            },
            {
                "source": "**",
                "destination": "/index.html"
            }
        ],
        "headers": [
            {
                "source": "/.well-known/apple-app-site-association",
                "headers": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ]
            },
            {
                "source": "/.well-known/testfile",
                "headers": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ]
            },
            {
                "source": "/_astro/**",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "public, max-age=31536000, immutable"
                    }
                ]
            },
            {
                "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|js|css|eot|otf|ttf|ttc|woff|woff2|font.css)",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "public, max-age=31536000, immutable"
                    }
                ]
            }
        ]
    }],
    "functions": {
        "source": "functions"
    },
    "emulators": {
        "hosting": {
            "host": "0.0.0.0",
            "port": 5003
        }
    }
}