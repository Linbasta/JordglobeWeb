{
  "name": "@jordglobe/games",
  "version": "1.0.0",
  "description": "JordGlobe geography quiz games - Babylon.js globe engine",
  "type": "module",
  "scripts": {
    "dev": "node scripts/check-log-server.mjs && astro dev",
    "build": "npm run check:slugs && ./scripts/build-prod.sh",
    "check:slugs": "tsx scripts/check-quiz-slugs.ts",
    "preview": "astro preview",
    "log-server": "node scripts/log-server.mjs",
    "test": "echo \"No unit tests configured\"",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:segments": "tsx scripts/test-segment-loader.ts",
    "test:quiz-runner": "tsx scripts/test-quiz-runner.ts",
    "test:small-countries": "tsx scripts/test-small-countries.ts",
    "test:expansion": "tsx scripts/test-expansion-formula.ts",
    "test:us-provinces": "tsx scripts/test-us-provinces.ts",
    "test:regions": "tsx scripts/test-regions.ts",
    "test:static-border-overlay": "tsx scripts/test-static-border-overlay.ts",
    "test:province-quiz-behavior": "tsx scripts/test-province-quiz-behavior.ts",
    "test:province-segments": "tsx scripts/test-province-segments.ts",
    "test:country-province-parity": "tsx scripts/test-country-province-parity.ts",
    "test:medal-integration": "tsx scripts/test-medal-integration.ts",
    "test:phase0": "npm run test:province-quiz-behavior && npm run test:province-segments && npm run test:country-province-parity && npm run test:medal-integration",
    "generate:qr": "tsx scripts/generate-qr.ts",
    "generate:borders": "node scripts/generate-borders.mjs",
    "generate:segments": "tsx scripts/generate-segments.ts",
    "generate:countries-bin": "tsx scripts/generate-countries-bin.ts",
    "generate:us-segments": "tsx scripts/generate-us-segments.ts",
    "generate:province-segments": "tsx scripts/generate-province-segments.ts",
    "generate:province-index": "tsx scripts/generate-province-index.ts",
    "generate:medal-menu": "tsx scripts/generate-medal-menu.ts",
    "data:enrich-countries": "tsx scripts/enrich-countries.ts",
    "data:convert-medals": "tsx scripts/convert-medals.ts",
    "data:convert-province-medals": "tsx scripts/convert-province-medals.ts",
    "data:extract-provinces": "tsx scripts/extract-provinces.ts",
    "data:extract-us-provinces": "tsx scripts/extract-us-provinces.ts"
  },
  "devDependencies": {
    "@babylonjs/inspector": "^7.54.3",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.6",
    "astro": "^6.1.7",
    "ts-morph": "^27.0.2",
    "tsx": "^4.20.6",
    "typescript": "^5.3.0",
    "vite": "^7.0.0",
    "ws": "^8.0.0"
  },
  "dependencies": {
    "@babylonjs/core": "^7.0.0",
    "@babylonjs/gui": "^7.54.3",
    "@babylonjs/loaders": "^7.54.3",
    "firebase": "^12.11.0",
    "firebaseui": "^6.1.0",
    "qrcode": "^1.5.4"
  }
}
