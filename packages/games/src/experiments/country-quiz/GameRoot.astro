<canvas id="renderCanvas"></canvas>

<style>
    html, body {
        height: 100%;
    }
    body {
        margin: 0;
        overflow: hidden;
        background-color: #6496DC;
    }
    body.placing-mode {
        cursor: none;
    }
    #renderCanvas {
        width: 100%;
        height: 100%;
        touch-action: none;
    }
</style>

<script>
    import { initMobile } from '../../shared/ui/mobile-init.ts';
    import { startQuizGame } from '../../solo/start-quiz-game.ts';

    initMobile();

    const countries = [
        { iso2: 'SE', name: 'Sweden' },
        { iso2: 'NO', name: 'Norway' },
        { iso2: 'FI', name: 'Finland' },
        { iso2: 'DK', name: 'Denmark' },
        { iso2: 'IS', name: 'Iceland' },
        { iso2: 'GB', name: 'United Kingdom' },
        { iso2: 'IE', name: 'Ireland' },
        { iso2: 'FR', name: 'France' },
        { iso2: 'ES', name: 'Spain' },
        { iso2: 'PT', name: 'Portugal' },
        { iso2: 'DE', name: 'Germany' },
        { iso2: 'NL', name: 'Netherlands' },
        { iso2: 'BE', name: 'Belgium' },
        { iso2: 'LU', name: 'Luxembourg' },
        { iso2: 'CH', name: 'Switzerland' },
        { iso2: 'AT', name: 'Austria' },
        { iso2: 'IT', name: 'Italy' },
        { iso2: 'GR', name: 'Greece' },
        { iso2: 'MT', name: 'Malta' },
        { iso2: 'CY', name: 'Cyprus' },
        { iso2: 'MC', name: 'Monaco' },
        { iso2: 'SM', name: 'San Marino' },
        { iso2: 'VA', name: 'Vatican City' },
        { iso2: 'LI', name: 'Liechtenstein' },
        { iso2: 'PL', name: 'Poland' },
        { iso2: 'CZ', name: 'Czech Republic' },
        { iso2: 'SK', name: 'Slovakia' },
        { iso2: 'HU', name: 'Hungary' },
        { iso2: 'RO', name: 'Romania' },
        { iso2: 'BG', name: 'Bulgaria' },
        { iso2: 'EE', name: 'Estonia' },
        { iso2: 'LV', name: 'Latvia' },
        { iso2: 'LT', name: 'Lithuania' },
    ];

    startQuizGame({
        title: 'Country Quiz',
        questions: countries.map((country) => ({
            present: 'text',
            answer: 'country',
            countryISO2: country.iso2,
            prompt: country.name,
        })),
        onGameComplete: (score, total) => {
            alert(`Quiz Complete!\n\nScore: ${score}/${total}\n\nReload page to play again!`);
        },
    });
</script>
