<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>US States Quiz</title>
    </head>
    <body>
        <canvas id="renderCanvas"></canvas>
    </body>
</html>

<style>
    body {
        margin: 0;
        overflow: hidden;
    }
    body.placing-mode {
        cursor: none;
    }
    #renderCanvas {
        width: 100%;
        height: 100vh;
        touch-action: none;
    }
</style>

<script>
    import { startQuizGame } from '../solo/start-quiz-game.ts';

    // US States quiz - using province IDs from public-prod/provinces/US.json
    const states = [
        { id: 4, name: 'California' },
        { id: 42, name: 'Texas' },
        { id: 8, name: 'Florida' },
        { id: 31, name: 'New York' },
        { id: 1, name: 'Alaska' },
    ];

    startQuizGame({
        title: 'Loading US States Quiz',
        questions: states.map((state) => ({
            present: 'text',
            answer: 'province',
            provinceId: state.id,
            countryISO2: 'US',
            prompt: state.name,
        })),
        shuffle: false,
        onGameComplete: (score: number, total: number) => {
            alert(`Quiz Complete!\n\nScore: ${score}/${total}\n\nReload page to play again!`);
        },
    });
</script>
