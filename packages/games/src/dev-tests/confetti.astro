<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <title>Test: Confetti Effect</title>
    </head>
    <body>
        <div id="backdrop">
            <div id="card">
                <h1>Congratulations!</h1>
                <p>10 / 10 correct</p>
                <div class="time">1:23</div>
            </div>
        </div>

        <div id="controls">
            <button id="btnLaunch">Launch Confetti</button>
            <button id="btnStop">Stop Confetti</button>
        </div>
    </body>
</html>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    body {
        background: #1a1a2e;
        overflow: hidden;
        font-family: monospace;
    }

    #backdrop {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.6);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    #card {
        width: 320px;
        background: #fff;
        border-radius: 12px;
        padding: 32px;
        text-align: center;
        z-index: 1;
    }
    #card h1 {
        color: #4caf50;
        font-size: 28px;
        margin-bottom: 12px;
    }
    #card p {
        color: #666;
        font-size: 18px;
        margin-bottom: 8px;
    }
    #card .time {
        color: #4caf50;
        font-size: 32px;
        font-weight: bold;
        margin-bottom: 24px;
    }

    #controls {
        position: fixed;
        top: 16px;
        left: 16px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        z-index: 100;
    }

    button {
        padding: 10px 20px;
        font-family: monospace;
        font-size: 14px;
        cursor: pointer;
        border: 1px solid #888;
        border-radius: 4px;
        background: rgba(0, 0, 0, 0.8);
        color: #fff;
    }
    button:hover {
        background: rgba(60, 60, 60, 0.9);
    }
</style>

<script>
    import { startConfetti, stopConfetti } from '../shared/ui/confetti.ts';

    const backdrop = document.getElementById('backdrop')!;
    const card = document.getElementById('card')!;

    document.getElementById('btnLaunch')!.addEventListener('click', () => {
        stopConfetti();
        startConfetti(backdrop, card);
    });

    document.getElementById('btnStop')!.addEventListener('click', () => {
        stopConfetti();
    });

    startConfetti(backdrop, card);
</script>
