<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Test: Result Popup</title>
    </head>
    <body>
        <div id="auth-widget">
            <div id="auth-state">Checking...</div>
            <button id="auth-action"></button>
        </div>

        <div id="controls">
            <div class="section-label">Manual Tests</div>
            <button data-action="show" data-args="10,10,83000">Perfect: 10/10, 1:23</button>
            <button data-action="show" data-args="8,10,102000">Good: 8/10, 1:42</button>
            <button data-action="show" data-args="5,10,145000">Mid: 5/10, 2:25</button>
            <button data-action="show" data-args="2,10,200000">Bad: 2/10, 3:20</button>
            <button data-action="show" data-args="35,35,312000">Perfect 35: 35/35, 5:12</button>
            <button data-action="show" data-args="1,35,400000">Bad 35: 1/35, 6:40</button>
            <button data-action="show-record" data-args="10,10,83000">World Record!</button>
            <button data-action="show-pb" data-args="8,10,90000">Personal Best!</button>

            <div class="section-label">Personal Best (localStorage)</div>
            <div id="pb-status">Loading...</div>
            <button class="pb-test" data-action="test-pb" data-args="5,10,120000">Play: 5/10, 2:00</button>
            <button class="pb-test" data-action="test-pb" data-args="7,10,100000">Play: 7/10, 1:40</button>
            <button class="pb-test" data-action="test-pb" data-args="8,10,90000">Play: 8/10, 1:30</button>
            <button class="pb-test" data-action="test-pb" data-args="8,10,70000">Play: 8/10, 1:10 (faster)</button>
            <button class="danger" data-action="clear-pb">Clear Personal Best</button>

            <div class="section-label">Leaderboard Popup</div>
            <button data-action="leaderboard" data-args="8,10,102000">Leaderboard: 8/10</button>
            <button data-action="leaderboard" data-args="10,10,83000">Leaderboard: 10/10 (PB)</button>
            <button data-action="leaderboard-fake" data-args="5,10,180000">Fake: full board, you outside top 10</button>
            <button data-action="leaderboard-fake-sparse" data-args="8,10,90000">Fake: sparse daily (2), full weekly</button>
            <button data-action="leaderboard-fake-empty" data-args="8,10,90000">Fake: empty daily, full weekly</button>

            <div class="section-label">Score Bar Preview</div>
            <button data-action="toggle-score-bar">Toggle Score Bar</button>
        </div>
    </body>
</html>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    body {
        background: #0a1628;
        font-family: 'Arial', sans-serif;
    }

    #controls {
        position: fixed;
        top: 16px;
        left: 16px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        z-index: 300;
        max-width: 280px;
    }

    #controls button {
        padding: 8px 16px;
        font-family: monospace;
        font-size: 13px;
        cursor: pointer;
        border: 1px solid #555;
        border-radius: 4px;
        background: rgba(0, 0, 0, 0.8);
        color: #fff;
    }
    #controls button:hover {
        background: rgba(60, 60, 60, 0.9);
    }

    .section-label {
        color: #7eb8e0;
        font-size: 11px;
        font-family: monospace;
        margin-top: 8px;
        margin-bottom: 4px;
        text-transform: uppercase;
    }

    #pb-status {
        color: #7cf6ff;
        font-size: 12px;
        font-family: monospace;
        padding: 8px;
        background: rgba(0, 0, 0, 0.5);
        border-radius: 4px;
        line-height: 1.4;
    }

    #auth-widget {
        position: fixed;
        top: 16px;
        right: 16px;
        z-index: 500;
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 6px;
    }
    #auth-state {
        font-family: monospace;
        font-size: 12px;
        padding: 8px 12px;
        border-radius: 6px;
        background: rgba(0,0,0,0.8);
        max-width: 220px;
        word-break: break-all;
    }
    #auth-state.logged-in { color: #6bff6b; border: 1px solid #2a5a2a; }
    #auth-state.logged-out { color: #ff6b6b; border: 1px solid #5a2a2a; }
    #auth-action {
        padding: 6px 14px;
        font-family: monospace;
        font-size: 12px;
        cursor: pointer;
        border: 1px solid #555;
        border-radius: 4px;
        background: rgba(0,0,0,0.8);
        color: #fff;
    }
    #auth-action:hover { background: rgba(60,60,60,0.9); }

    button.danger {
        background: rgba(180, 50, 50, 0.8);
        border-color: #a33;
    }
    button.danger:hover {
        background: rgba(200, 60, 60, 0.9);
    }

    button.pb-test {
        background: rgba(50, 100, 150, 0.8);
        border-color: #4a8;
    }
    button.pb-test:hover {
        background: rgba(60, 120, 170, 0.9);
    }
</style>

<script>
    import {
        showResultOverlay,
        hideResultOverlay,
        getPersonalBest,
        checkAndUpdatePersonalBest,
        clearPersonalBest,
    } from '../shared/ui/result-overlay.ts';
    import { auth } from '../shared/firebase.ts';
    import { onAuthStateChanged, signOut } from 'firebase/auth';
    import { showLoginModal } from '../shared/ui/login-modal.ts';
    import {
        createSimpleScoreBar,
        updateSimpleScoreBar,
        disposeSimpleScoreBar,
    } from '../shared/ui/score-bar-simple.ts';
    import sprite1 from '../games/euro-music-quiz/assets/1.png?url';
    import sprite2 from '../games/euro-music-quiz/assets/2.png?url';
    import sprite3 from '../games/euro-music-quiz/assets/3.png?url';
    import sprite4 from '../games/euro-music-quiz/assets/4.png?url';
    import sprite5 from '../games/euro-music-quiz/assets/5.png?url';
    import sprite6 from '../games/euro-music-quiz/assets/6.png?url';
    const SPRITE_URLS = [sprite1, sprite2, sprite3, sprite4, sprite5, sprite6];

    const QUIZ_ID = 'test-quiz';
    let scoreBarVisible = false;
    let scoreBarTimer: any = null;

    function randomResults(score: number, total: number) {
        const arr = Array(score).fill(true).concat(Array(total - score).fill(false));
        for (let i = arr.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [arr[i], arr[j]] = [arr[j], arr[i]];
        }
        return arr;
    }

    function formatTime(ms: number) {
        const totalSeconds = Math.floor(ms / 1000);
        const minutes = Math.floor(totalSeconds / 60);
        const seconds = totalSeconds % 60;
        return `${minutes}:${seconds.toString().padStart(2, '0')}`;
    }

    function updatePBStatus() {
        const pb = getPersonalBest(QUIZ_ID);
        const statusEl = document.getElementById('pb-status')!;
        if (pb) {
            statusEl.textContent = `Current PB: ${pb.score}/${pb.total} in ${formatTime(pb.elapsedMs)}`;
        } else {
            statusEl.textContent = 'No personal best yet';
        }
    }

    const spriteNames = ['Nul Points', 'Mildly Aware', 'Semi-Curious', 'Music Lover', 'Devoted Fan', 'Music God'];

    function show(score: number, total: number, elapsedMs: number, opts: any = {}) {
        showResultOverlay({
            score,
            total,
            elapsedMs,
            results: randomResults(score, total),
            quizTitle: 'Euro Music Quiz',
            shareUrl: 'https://jordglobe.com/games/euro-music-quiz',
            shareEmoji: '🎵',
            sprites: SPRITE_URLS,
            spriteNames,
            getMessage: (s: number, t: number) =>
                spriteNames[Math.max(0, Math.min(5, Math.ceil((s / t) * 6) - 1))],
            isPersonalBest: opts.isPersonalBest || false,
            onSeeRanking: async () => {
                const { showLeaderboardWithAuth } = await import('../shared/ui/leaderboard-popup.ts');
                showLeaderboardWithAuth({
                    quizId: 'test-quiz',
                    userScore: score,
                    userTotal: total,
                    userElapsedMs: elapsedMs,
                    isPersonalBest: opts.isPersonalBest || false,
                    onClose: () => {},
                });
            },
            onRetry: () => hideResultOverlay(),
        });
    }

    function testWithPB(score: number, total: number, elapsedMs: number) {
        const isPersonalBest = checkAndUpdatePersonalBest(QUIZ_ID, score, total, elapsedMs);
        updatePBStatus();
        console.log(`Score: ${score}/${total}, Time: ${formatTime(elapsedMs)}, Personal Best: ${isPersonalBest}`);

        showResultOverlay({
            score,
            total,
            elapsedMs,
            results: randomResults(score, total),
            quizTitle: 'Euro Music Quiz',
            shareUrl: 'https://jordglobe.com/games/euro-music-quiz',
            shareEmoji: '🎵',
            sprites: SPRITE_URLS,
            spriteNames,
            getMessage: (s: number, t: number) =>
                spriteNames[Math.max(0, Math.min(5, Math.ceil((s / t) * 6) - 1))],
            isPersonalBest,
            onRetry: () => hideResultOverlay(),
        });
    }

    function clearPB() {
        clearPersonalBest(QUIZ_ID);
        updatePBStatus();
        console.log('Personal best cleared');
    }

    function toggleScoreBar() {
        if (scoreBarVisible) {
            disposeSimpleScoreBar();
            if (scoreBarTimer) {
                clearInterval(scoreBarTimer);
                scoreBarTimer = null;
            }
            scoreBarVisible = false;
            console.log('Score bar hidden');
        } else {
            createSimpleScoreBar(10, 10, QUIZ_ID);
            let elapsed = 0;
            let score = 0;
            scoreBarTimer = setInterval(() => {
                elapsed += 1000;
                if (Math.random() < 0.3 && score < 10) score++;
                updateSimpleScoreBar(score, 10 - score, 10, elapsed);
            }, 1000);
            scoreBarVisible = true;
            console.log('Score bar shown with PB:', getPersonalBest(QUIZ_ID));
        }
    }

    document.querySelectorAll<HTMLButtonElement>('#controls button[data-action]').forEach((btn) => {
        btn.addEventListener('click', () => {
            const action = btn.dataset.action!;
            const args = (btn.dataset.args || '').split(',').map((s) => parseInt(s, 10));
            switch (action) {
                case 'show':
                    show(args[0], args[1], args[2]);
                    break;
                case 'show-record':
                    show(args[0], args[1], args[2], { isPersonalBest: true });
                    break;
                case 'show-pb':
                    show(args[0], args[1], args[2], { isPersonalBest: true });
                    break;
                case 'test-pb':
                    testWithPB(args[0], args[1], args[2]);
                    break;
                case 'clear-pb':
                    clearPB();
                    break;
                case 'leaderboard':
                    import('../shared/ui/leaderboard-popup.ts').then(({ showLeaderboardWithAuth }) => {
                        showLeaderboardWithAuth({
                            quizId: 'test-quiz',
                            userScore: args[0],
                            userTotal: args[1],
                            userElapsedMs: args[2],
                            isPersonalBest: false,
                            onClose: () => {},
                        });
                    });
                    break;
                case 'leaderboard-fake':
                    import('../shared/ui/leaderboard-popup.ts').then(({ showLeaderboardPopup, fillWithData }) => {
                        const handle = showLeaderboardPopup(() => {});
                        const fakeDaily = [
                            { name: 'Alice', score: 10, total: 10, elapsed_ms: 62000, created_at: '' },
                            { name: 'Bob', score: 10, total: 10, elapsed_ms: 71000, created_at: '' },
                            { name: 'Charlie', score: 10, total: 10, elapsed_ms: 85000, created_at: '' },
                            { name: 'Diana', score: 9, total: 10, elapsed_ms: 58000, created_at: '' },
                            { name: 'Eve', score: 9, total: 10, elapsed_ms: 73000, created_at: '' },
                            { name: 'Frank', score: 9, total: 10, elapsed_ms: 91000, created_at: '' },
                            { name: 'Grace', score: 8, total: 10, elapsed_ms: 66000, created_at: '' },
                            { name: 'Hank', score: 8, total: 10, elapsed_ms: 78000, created_at: '' },
                            { name: 'Ivy', score: 8, total: 10, elapsed_ms: 95000, created_at: '' },
                            { name: 'Jack', score: 7, total: 10, elapsed_ms: 82000, created_at: '' },
                        ];
                        const fakeWeekly = [
                            { name: 'Zara', score: 10, total: 10, elapsed_ms: 55000, created_at: '' },
                            ...fakeDaily,
                        ].slice(0, 10);
                        fillWithData(handle, fakeDaily, fakeWeekly, args[0], args[1], args[2]);
                    });
                    break;
                case 'leaderboard-fake-sparse':
                    import('../shared/ui/leaderboard-popup.ts').then(({ showLeaderboardPopup, fillWithData }) => {
                        const handle = showLeaderboardPopup(() => {});
                        const fakeDaily = [
                            { name: 'Alice', score: 10, total: 10, elapsed_ms: 62000, created_at: '' },
                            { name: 'Bob', score: 9, total: 10, elapsed_ms: 71000, created_at: '' },
                        ];
                        const fakeWeekly = [
                            { name: 'Zara', score: 10, total: 10, elapsed_ms: 55000, created_at: '' },
                            { name: 'Alice', score: 10, total: 10, elapsed_ms: 62000, created_at: '' },
                            { name: 'Yves', score: 10, total: 10, elapsed_ms: 68000, created_at: '' },
                            { name: 'Bob', score: 9, total: 10, elapsed_ms: 71000, created_at: '' },
                            { name: 'Xena', score: 9, total: 10, elapsed_ms: 74000, created_at: '' },
                            { name: 'Will', score: 8, total: 10, elapsed_ms: 66000, created_at: '' },
                            { name: 'Vera', score: 8, total: 10, elapsed_ms: 88000, created_at: '' },
                            { name: 'Uma', score: 7, total: 10, elapsed_ms: 70000, created_at: '' },
                        ];
                        fillWithData(handle, fakeDaily, fakeWeekly, args[0], args[1], args[2]);
                    });
                    break;
                case 'leaderboard-fake-empty':
                    import('../shared/ui/leaderboard-popup.ts').then(({ showLeaderboardPopup, fillWithData }) => {
                        const handle = showLeaderboardPopup(() => {});
                        const fakeWeekly = [
                            { name: 'Zara', score: 10, total: 10, elapsed_ms: 55000, created_at: '' },
                            { name: 'Yves', score: 10, total: 10, elapsed_ms: 68000, created_at: '' },
                            { name: 'Xena', score: 9, total: 10, elapsed_ms: 74000, created_at: '' },
                            { name: 'Will', score: 8, total: 10, elapsed_ms: 66000, created_at: '' },
                            { name: 'Vera', score: 8, total: 10, elapsed_ms: 88000, created_at: '' },
                            { name: 'Uma', score: 7, total: 10, elapsed_ms: 70000, created_at: '' },
                        ];
                        fillWithData(handle, [], fakeWeekly, args[0], args[1], args[2]);
                    });
                    break;
                case 'toggle-score-bar':
                    toggleScoreBar();
                    break;
            }
        });
    });

    updatePBStatus();
    show(8, 10, 102000);

    // --- Auth widget ---
    const authStateEl = document.getElementById('auth-state')!;
    const authActionBtn = document.getElementById('auth-action') as HTMLButtonElement;

    function updateAuthWidget() {
        const user = auth.currentUser;
        if (user && !user.isAnonymous) {
            authStateEl.textContent = `Logged in: ${user.email ?? user.uid}`;
            authStateEl.className = 'logged-in';
            authActionBtn.textContent = 'Sign out';
            authActionBtn.onclick = () => signOut(auth);
        } else {
            authStateEl.textContent = user ? `Anonymous: ${user.uid}` : 'Not logged in';
            authStateEl.className = 'logged-out';
            authActionBtn.textContent = 'Sign in';
            authActionBtn.onclick = () => {
                showLoginModal({
                    onSuccess: () => {},
                    onCancel: () => {},
                });
            };
        }
    }

    onAuthStateChanged(auth, () => updateAuthWidget());
    updateAuthWidget();
</script>
