<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <title>Test: Region Mode</title>
    </head>
    <body>
        <canvas id="renderCanvas"></canvas>

        <div id="ui">
            <button id="btnEnter" disabled>Enter US region mode</button>
            <button id="btnExit" disabled>Exit region mode</button>
            <div id="status">Initializing…</div>
        </div>
    </body>
</html>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    body {
        background: #000;
        overflow: hidden;
        font-family: monospace;
    }
    #renderCanvas {
        width: 100vw;
        height: 100vh;
        display: block;
    }

    #ui {
        position: fixed;
        top: 16px;
        left: 16px;
        display: flex;
        flex-direction: column;
        gap: 8px;
        z-index: 10;
    }

    button {
        padding: 8px 16px;
        font-family: monospace;
        font-size: 13px;
        cursor: pointer;
        border: 1px solid #888;
        border-radius: 4px;
        background: rgba(0, 0, 0, 0.7);
        color: #fff;
    }
    button:hover {
        background: rgba(40, 40, 40, 0.9);
    }
    button:disabled {
        opacity: 0.4;
        cursor: default;
    }

    #status {
        padding: 6px 10px;
        font-size: 12px;
        color: #ccc;
        background: rgba(0, 0, 0, 0.6);
        border-radius: 4px;
        border: 1px solid #444;
    }
</style>

<script>
    import { EarthGlobe } from '../earth-globe/index.ts';

    const btnEnter = document.getElementById('btnEnter') as HTMLButtonElement;
    const btnExit = document.getElementById('btnExit') as HTMLButtonElement;
    const statusEl = document.getElementById('status')!;

    function setStatus(text: string) {
        statusEl.textContent = text;
    }

    new EarthGlobe({
        canvasId: 'renderCanvas',
        onReady: (g: any) => {
            setStatus('Globe ready — waiting for provinces…');

            (window as any).globe = g;

            btnEnter.disabled = false;
            btnEnter.addEventListener('click', async () => {
                await g.enterRegionMode('US');

                const regions = g.getAllActiveRegions();
                for (const region of regions) {
                    const target = 0.2 + Math.random() * 0.8;
                    g.animateActiveRegionAltitude(region.index, target, 800 + Math.random() * 400);
                }

                setStatus(`Region mode: US (${regions.length} states, random altitudes)`);
                btnEnter.disabled = true;
                btnExit.disabled = false;
            });

            btnExit.addEventListener('click', () => {
                g.exitRegionMode();
                setStatus('Country mode');
                btnExit.disabled = true;
                btnEnter.disabled = false;
            });

            const pollInterval = setInterval(() => {
                if (g.isInRegionMode()) return;
                if (g.isReady()) {
                    setStatus('Ready — click "Enter US region mode"');
                    clearInterval(pollInterval);
                }
            }, 500);
        },
    });
</script>
