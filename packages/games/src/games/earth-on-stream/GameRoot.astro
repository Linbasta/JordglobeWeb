<div id="game-layout">
    <div id="globe-area">
        <canvas id="renderCanvas"></canvas>
    </div>
    <div id="side-panel"></div>
</div>

<style>
    #game-layout {
        display: flex;
        width: 100%;
        height: 100%;
    }
    #globe-area {
        flex: 1;
        position: relative;
        min-width: 0;
        overflow: hidden;
    }
    #renderCanvas {
        width: 100%;
        height: 100%;
        touch-action: none;
    }
    #side-panel {
        flex: 0 0 auto;
        width: 0;
        overflow: hidden;
        transition: width 0.3s ease;
    }
</style>

<script>
    import { EarthGlobe } from '../../earth-globe/earth-globe.ts';
    import { Color4 } from '@babylonjs/core/Maths/math';
    import { animateToLocation } from '../../shared/animation/camera-utils.ts';
    import { loadAllLocations, filterByContinent } from './locations.ts';
    import type { LocationSet, Continent } from './locations.ts';
    import { showLobby } from './lobby-ui.ts';
    import {
        startSession, startRound, processGuess, getGuessedCount, getRoundTotal,
        isRoundComplete, resetRound, getRemainingLocations, getRoundLocation,
        getSessionRoundNumber, getGlobalRoundScore, getCurrentRoundGoal,
        isRoundGoalMet, advanceRound, getLeaderboard, getHighestRound,
        updateHighestRound, cheatClearRound,
    } from './game-state.ts';
    import { createSidebar, revealLocation, updateCounter, updateScore, disposeSidebar, highlightRow } from './sidebar-ui.ts';
    import { playCorrectEffect } from './globe-effects.ts';
    import { createTimer, disposeTimer } from './timer-ui.ts';
    import { showLeaderboard, disposeLeaderboard } from './leaderboard-ui.ts';
    import { startConfetti } from '../../shared/ui/confetti.ts';
    import { handleOAuthRedirect, getStoredAuth, startOAuthFlow, disconnect as disconnectAuth } from './twitch-auth.ts';
    import { connectChat, disconnectChat } from './twitch-chat.ts';
    import { createTwitchUI, setTwitchConnected, setTwitchDisconnected } from './twitch-ui.ts';
    import { playCorrectSfx, playFanfareSuccess, playFanfareFail } from '../../shared/sfx/sfx-player.ts';
    import { startRoundMusic, stopRoundMusic, startMenuMusic, stopMenuMusic, getMusicVolume, setMusicVolume, onVolumeChange } from './round-music.ts';

    const ROUND_SIZE_MIN = 8;
    const ROUND_SIZE_MAX = 12;
    const ROUND_TIME = 120;
    const FRAME_RADIUS = 5.5;
    let dwellTime = 3500;
    let flyDuration = 3000;

    let cycleTimer: ReturnType<typeof setTimeout> | null = null;
    let cycleGen = 0;
    let animating = false;
    let cycleQueue: number[] = [];
    let cyclePos = 0;
    let twitchActive = false;
    let locationSet: LocationSet;
    let activeSet: LocationSet;
    let selectedContinent: Continent = 'world';

    const auth = await handleOAuthRedirect() ?? getStoredAuth();

    const globe = new EarthGlobe({
        canvasId: 'renderCanvas',
        onReady: async () => {
            const scene = globe.getScene();
            scene.clearColor = new Color4(10 / 255, 10 / 255, 26 / 255, 1);
            const skybox = scene.getMeshByName('skyBox');
            if (skybox) skybox.setEnabled(false);

            globe.getCamera().detachControl();
            initTwitchUI();
            if (auth) {
                activateTwitch(auth.accessToken, auth.twitchLogin, auth.displayName);
            }
            locationSet = await loadAllLocations();
            openLobby();
        },
    });

    function createSettingsMenu() {
        const parent = document.getElementById('globe-area')!;

        const toggle = document.createElement('button');
        toggle.textContent = '⚙';
        toggle.style.cssText =
            'position:absolute;top:12px;left:12px;z-index:70;' +
            'width:36px;height:36px;border-radius:8px;border:none;cursor:pointer;' +
            'background:rgba(255,255,255,0.12);color:#fff;font-size:20px;' +
            'display:flex;align-items:center;justify-content:center;' +
            'backdrop-filter:blur(6px);';
        parent.appendChild(toggle);

        const panel = document.createElement('div');
        panel.style.cssText =
            'position:absolute;top:54px;left:12px;z-index:70;' +
            'background:rgba(10,10,20,0.85);backdrop-filter:blur(8px);' +
            'border:1px solid rgba(255,255,255,0.15);border-radius:10px;' +
            'padding:14px 16px;display:none;flex-direction:column;gap:12px;' +
            'font-family:system-ui,-apple-system,sans-serif;min-width:200px;' +
            'box-shadow:0 4px 20px rgba(0,0,0,0.5);';
        parent.appendChild(panel);

        toggle.addEventListener('click', () => {
            panel.style.display = panel.style.display === 'none' ? 'flex' : 'none';
        });

        function addSlider(label: string, min: number, max: number, value: number, step: number, fmt: (v: number) => string, onChange: (v: number) => void) {
            const wrap = document.createElement('div');
            wrap.style.cssText = 'display:flex;flex-direction:column;gap:4px;';

            const header = document.createElement('div');
            header.style.cssText = 'display:flex;justify-content:space-between;align-items:center;';

            const lbl = document.createElement('span');
            lbl.style.cssText = 'color:#ccc;font-size:12px;font-weight:600;';
            lbl.textContent = label;
            header.appendChild(lbl);

            const val = document.createElement('span');
            val.style.cssText = 'color:#fff;font-size:12px;font-weight:700;';
            val.textContent = fmt(value);
            header.appendChild(val);

            wrap.appendChild(header);

            const slider = document.createElement('input');
            slider.type = 'range';
            slider.min = String(min);
            slider.max = String(max);
            slider.step = String(step);
            slider.value = String(value);
            slider.style.cssText = 'width:100%;accent-color:#4CAF50;';
            slider.addEventListener('input', () => {
                const v = Number(slider.value);
                val.textContent = fmt(v);
                onChange(v);
            });
            wrap.appendChild(slider);
            panel.appendChild(wrap);
            return { slider, display: val };
        }

        const volSlider = addSlider('Music Volume', 0, 100, getMusicVolume() * 100, 1,
            (v) => `${Math.round(v)}%`,
            (v) => { setMusicVolume(v / 100); },
        );
        onVolumeChange((v) => {
            volSlider.slider.value = String(v * 100);
            volSlider.display.textContent = `${Math.round(v * 100)}%`;
        });

        addSlider('Dwell Time', 500, 10000, dwellTime, 250,
            (v) => `${(v / 1000).toFixed(1)}s`,
            (v) => { dwellTime = v; },
        );
        addSlider('Fly Duration', 500, 8000, flyDuration, 250,
            (v) => `${(v / 1000).toFixed(1)}s`,
            (v) => { flyDuration = v; },
        );
    }
    createSettingsMenu();

    let twitchChannel = '';

    function initTwitchUI() {
        createTwitchUI({
            onConnect: () => startOAuthFlow(),
            onDisconnect: () => doTwitchDisconnect(),
        });
    }

    function doTwitchDisconnect() {
        disconnectChat();
        disconnectAuth();
        const wasActive = twitchActive;
        twitchActive = false;
        twitchChannel = '';
        setTwitchDisconnected();

        if (wasActive) {
            stopCycling();
            stopRoundMusic();
            disposeTimer();
            disposeLeaderboard();
            resetRound(globe);
            disposeSidebar();
            openLobby();
        }
    }

    function activateTwitch(token: string, login: string, displayName: string) {
        twitchActive = true;
        twitchChannel = displayName;
        setTwitchConnected(displayName);
        connectChat(token, login, onChatMessage);
    }

    function onChatMessage(username: string, text: string) {
        onGuess(text, username);
    }

    function buildCycleQueue() {
        const indices = Array.from({ length: getRoundTotal() }, (_, i) => i);
        for (let i = indices.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [indices[i], indices[j]] = [indices[j], indices[i]];
        }
        cycleQueue = indices;
        cyclePos = 0;
    }

    function startCycling() {
        stopCycling();
        const gen = ++cycleGen;
        cycleToNext(gen);
    }

    function resumeCycling() {
        stopCycling();
        const gen = ++cycleGen;
        cycleToNext(gen);
    }

    function stopCycling() {
        cycleGen++;
        if (cycleTimer) {
            clearTimeout(cycleTimer);
            cycleTimer = null;
        }
    }

    function nextUnguessedInQueue(): number | null {
        const len = cycleQueue.length;
        for (let i = 0; i < len; i++) {
            const idx = cycleQueue[(cyclePos + i) % len];
            const rl = getRoundLocation(idx);
            if (rl && !rl.guessed) {
                cyclePos = (cyclePos + i) % len;
                return idx;
            }
        }
        return null;
    }

    async function cycleToNext(gen: number) {
        if (gen !== cycleGen || animating) return;

        const idx = nextUnguessedInQueue();
        if (idx === null) return;

        const rl = getRoundLocation(idx)!;
        highlightRow(rl.index);

        await animateToLocation(globe.getCamera(), rl.location.lat, rl.location.lon, FRAME_RADIUS, flyDuration);

        if (gen !== cycleGen) return;
        cyclePos = (cyclePos + 1) % cycleQueue.length;
        cycleTimer = setTimeout(() => cycleToNext(gen), dwellTime);
    }

    function openLobby() {
        startMenuMusic();
        showLobby({
            defaultContinent: selectedContinent,
            getHighestRound,
            twitchConnected: twitchActive,
            twitchChannel: twitchChannel || undefined,
            onTwitchConnect: () => startOAuthFlow(),
            onTwitchDisconnect: () => doTwitchDisconnect(),
            onStart: (continent) => {
                selectedContinent = continent;
                activeSet = filterByContinent(locationSet, continent);
                startSession();
                beginRound();
            },
        });
    }

    function beginRound() {
        const roundNum = getSessionRoundNumber();
        updateHighestRound(selectedContinent, roundNum);
        const roundSize = ROUND_SIZE_MIN + Math.floor(Math.random() * (ROUND_SIZE_MAX - ROUND_SIZE_MIN + 1));
        const locations = startRound(globe, activeSet, roundSize);
        const goal = getCurrentRoundGoal();
        createSidebar(locations, roundNum, goal);
        createTimer(ROUND_TIME, onTimeUp);
        startRoundMusic(ROUND_TIME);
        buildCycleQueue();
        startCycling();
    }

    function onTimeUp() {
        stopCycling();
        onRoundEnd();
    }

    async function onGuess(text: string, username: string) {
        const result = processGuess(text, username);
        if (!result) return;

        playCorrectSfx();
        stopCycling();
        animating = true;

        await Promise.all([
            playCorrectEffect(globe, result.match.markerId),
            revealLocation(result.match.index, username),
        ]);

        animating = false;
        updateCounter(getGuessedCount(), getRoundTotal());
        updateScore(getGlobalRoundScore(), getCurrentRoundGoal());

        if (isRoundComplete()) {
            onRoundEnd();
        } else {
            resumeCycling();
        }
    }

    async function devCheatClear() {
        stopCycling();
        animating = true;
        const revealed = cheatClearRound();
        for (const rl of revealed) {
            await revealLocation(rl.index, 'DEV');
        }
        animating = false;
        updateCounter(getGuessedCount(), getRoundTotal());
        updateScore(getGlobalRoundScore(), getCurrentRoundGoal());
        onRoundEnd();
    }

    if (import.meta.env.DEV) {
        document.addEventListener('keydown', (e) => {
            if (e.key === '0') devCheatClear();
        });
    }

    function onRoundEnd() {
        stopCycling();
        stopRoundMusic();
        disposeTimer();

        const goalMet = isRoundGoalMet();

        if (goalMet) {
            playFanfareSuccess();
            startConfetti(document.body, document.body, 3);
        } else {
            playFanfareFail();
        }

        showLeaderboard({
            roundNumber: getSessionRoundNumber(),
            score: getGlobalRoundScore(),
            goal: getCurrentRoundGoal(),
            goalMet,
            players: getLeaderboard(),
            onAction: () => {
                resetRound(globe);
                disposeSidebar();

                if (goalMet) {
                    advanceRound();
                    beginRound();
                } else {
                    openLobby();
                }
            },
        });
    }
</script>
