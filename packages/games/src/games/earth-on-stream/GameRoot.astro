<div id="game-layout">
    <div id="globe-area">
        <canvas id="renderCanvas"></canvas>
    </div>
    <div id="side-panel"></div>
</div>

<style>
    #game-layout {
        display: flex;
        width: 100%;
        height: 100%;
    }
    #globe-area {
        flex: 1;
        position: relative;
        min-width: 0;
        overflow: hidden;
    }
    #renderCanvas {
        width: 100%;
        height: 100%;
        touch-action: none;
    }
    #side-panel {
        flex: 0 0 auto;
        width: 0;
        overflow: hidden;
        transition: width 0.3s ease;
    }
</style>

<script>
    import { EarthGlobe } from '../../earth-globe/earth-globe.ts';
    import { Color4 } from '@babylonjs/core/Maths/math';
    import { animateToLocation } from '../../shared/animation/camera-utils.ts';
    import { loadAllLocations, filterByContinent } from './locations.ts';
    import type { LocationSet, Continent } from './locations.ts';
    import { showLobby } from './lobby-ui.ts';
    import {
        startSession, startRound, processGuess, getGuessedCount, getRoundTotal,
        isRoundComplete, resetRound, getRemainingLocations, getSessionRoundNumber,
        getGlobalRoundScore, getCurrentRoundGoal, isRoundGoalMet, advanceRound,
        getLeaderboard, getHighestRound, updateHighestRound,
    } from './game-state.ts';
    import { createSidebar, revealLocation, updateCounter, updateScore, disposeSidebar } from './sidebar-ui.ts';
    import { playCorrectEffect } from './globe-effects.ts';
    import { createTimer, disposeTimer } from './timer-ui.ts';
    import { showLeaderboard, disposeLeaderboard } from './leaderboard-ui.ts';
    import { startConfetti } from '../../shared/ui/confetti.ts';
    import { handleOAuthRedirect, getStoredAuth, startOAuthFlow, disconnect as disconnectAuth } from './twitch-auth.ts';
    import { connectChat, disconnectChat } from './twitch-chat.ts';
    import { createTwitchUI, setTwitchConnected, setTwitchDisconnected } from './twitch-ui.ts';

    const ROUND_SIZE_MIN = 8;
    const ROUND_SIZE_MAX = 12;
    const ROUND_TIME = 120;
    const DWELL_TIME = 3500;
    const FLY_DURATION = 3000;
    const FRAME_RADIUS = 5.5;

    let cycleTimer: ReturnType<typeof setTimeout> | null = null;
    let cycleGen = 0;
    let animating = false;
    let twitchActive = false;
    let locationSet: LocationSet;
    let activeSet: LocationSet;
    let selectedContinent: Continent = 'world';

    const auth = await handleOAuthRedirect() ?? getStoredAuth();

    const globe = new EarthGlobe({
        canvasId: 'renderCanvas',
        onReady: async () => {
            const scene = globe.getScene();
            scene.clearColor = new Color4(10 / 255, 10 / 255, 26 / 255, 1);
            const skybox = scene.getMeshByName('skyBox');
            if (skybox) skybox.setEnabled(false);

            globe.getCamera().detachControl();
            initTwitchUI();
            if (auth) {
                activateTwitch(auth.accessToken, auth.twitchLogin, auth.displayName);
            }
            locationSet = await loadAllLocations();
            openLobby();
        },
    });

    let twitchChannel = '';

    function initTwitchUI() {
        createTwitchUI({
            onConnect: () => startOAuthFlow(),
            onDisconnect: () => doTwitchDisconnect(),
        });
    }

    function doTwitchDisconnect() {
        disconnectChat();
        disconnectAuth();
        const wasActive = twitchActive;
        twitchActive = false;
        twitchChannel = '';
        setTwitchDisconnected();

        if (wasActive) {
            stopCycling();
            disposeTimer();
            disposeLeaderboard();
            resetRound(globe);
            disposeSidebar();
            openLobby();
        }
    }

    function activateTwitch(token: string, login: string, displayName: string) {
        twitchActive = true;
        twitchChannel = displayName;
        setTwitchConnected(displayName);
        connectChat(token, login, onChatMessage);
    }

    function onChatMessage(username: string, text: string) {
        onGuess(text, username);
    }

    function startCycling() {
        stopCycling();
        const gen = ++cycleGen;
        cycleToNext(0, gen);
    }

    function stopCycling() {
        cycleGen++;
        if (cycleTimer) {
            clearTimeout(cycleTimer);
            cycleTimer = null;
        }
    }

    async function cycleToNext(currentIndex: number, gen: number) {
        if (gen !== cycleGen) return;
        const remaining = getRemainingLocations();
        if (remaining.length === 0 || animating) return;

        const idx = currentIndex % remaining.length;
        const loc = remaining[idx].location;

        await animateToLocation(globe.getCamera(), loc.lat, loc.lon, FRAME_RADIUS, FLY_DURATION);

        if (gen !== cycleGen) return;
        const nextIdx = (idx + 1) % Math.max(remaining.length, 1);
        cycleTimer = setTimeout(() => cycleToNext(nextIdx, gen), DWELL_TIME);
    }

    function openLobby() {
        showLobby({
            defaultContinent: selectedContinent,
            getHighestRound,
            twitchConnected: twitchActive,
            twitchChannel: twitchChannel || undefined,
            onTwitchConnect: () => startOAuthFlow(),
            onTwitchDisconnect: () => doTwitchDisconnect(),
            onStart: (continent) => {
                selectedContinent = continent;
                activeSet = filterByContinent(locationSet, continent);
                startSession();
                beginRound();
            },
        });
    }

    function beginRound() {
        const roundNum = getSessionRoundNumber();
        updateHighestRound(selectedContinent, roundNum);
        const roundSize = ROUND_SIZE_MIN + Math.floor(Math.random() * (ROUND_SIZE_MAX - ROUND_SIZE_MIN + 1));
        const locations = startRound(globe, activeSet, roundSize);
        const goal = getCurrentRoundGoal();
        createSidebar(locations, roundNum, goal);
        createTimer(ROUND_TIME, onTimeUp);
        startCycling();
    }

    function onTimeUp() {
        stopCycling();
        onRoundEnd();
    }

    async function onGuess(text: string, username: string) {
        const result = processGuess(text, username);
        if (!result) return;

        stopCycling();
        animating = true;

        await Promise.all([
            playCorrectEffect(globe, result.match.markerId),
            revealLocation(result.match.index, username),
        ]);

        animating = false;
        updateCounter(getGuessedCount(), getRoundTotal());
        updateScore(getGlobalRoundScore(), getCurrentRoundGoal());

        if (isRoundComplete()) {
            onRoundEnd();
        } else {
            startCycling();
        }
    }

    function onRoundEnd() {
        stopCycling();
        disposeTimer();

        const goalMet = isRoundGoalMet();

        if (goalMet) {
            startConfetti(document.body, document.body, 3);
        }

        showLeaderboard({
            roundNumber: getSessionRoundNumber(),
            score: getGlobalRoundScore(),
            goal: getCurrentRoundGoal(),
            goalMet,
            players: getLeaderboard(),
            onAction: () => {
                resetRound(globe);
                disposeSidebar();

                if (goalMet) {
                    advanceRound();
                    beginRound();
                } else {
                    openLobby();
                }
            },
        });
    }
</script>
