<canvas id="renderCanvas"></canvas>

<style>
    #renderCanvas {
        width: 100%;
        height: 100%;
        touch-action: none;
    }
</style>

<script>
    import { EarthGlobe } from '../../earth-globe/earth-globe.ts';
    import { animateToLocation } from '../../shared/animation/camera-utils.ts';
    import { EUROPEAN_CAPITALS_SET } from './locations.ts';
    import { startRound, processGuess, getGuessedCount, getRoundTotal, isRoundComplete, resetRound, getRemainingLocations } from './game-state.ts';
    import { createSidebar, revealLocation, updateCounter, showCompletion, disposeSidebar, getSidebarWidth } from './sidebar-ui.ts';
    import { playCorrectEffect } from './globe-effects.ts';
    import { createTimer, disposeTimer } from './timer-ui.ts';
    import { startConfetti } from '../../shared/ui/confetti.ts';
    import { handleOAuthRedirect, getStoredAuth, startOAuthFlow, disconnect as disconnectAuth } from './twitch-auth.ts';
    import { connectChat, disconnectChat } from './twitch-chat.ts';
    import { createTwitchUI, setTwitchConnected, setTwitchDisconnected, disposeTwitchUI } from './twitch-ui.ts';

    const ROUND_SIZE = 6;
    const ROUND_TIME = 60;
    const DWELL_TIME = 1500;
    const FLY_DURATION = 1000;
    const FRAME_RADIUS = 5.5;

    let cycleTimer: ReturnType<typeof setTimeout> | null = null;
    let animating = false;
    let twitchActive = false;

    const auth = await handleOAuthRedirect() ?? getStoredAuth();

    const globe = new EarthGlobe({
        canvasId: 'renderCanvas',
        onReady: () => {
            globe.getCamera().detachControl();
            initTwitchUI();
            if (auth) {
                activateTwitch(auth.accessToken, auth.twitchLogin, auth.displayName);
            }
            beginRound();
        },
    });

    function initTwitchUI() {
        createTwitchUI({
            onConnect: () => startOAuthFlow(),
            onDisconnect: () => {
                disconnectChat();
                disconnectAuth();
                twitchActive = false;
                setTwitchDisconnected();
            },
        });
    }

    function activateTwitch(token: string, login: string, displayName: string) {
        twitchActive = true;
        setTwitchConnected(displayName);
        connectChat(token, login, onChatMessage);
    }

    function onChatMessage(username: string, text: string) {
        onGuess(text, username);
    }

    function startCycling() {
        stopCycling();
        cycleToNext(0);
    }

    function stopCycling() {
        if (cycleTimer) {
            clearTimeout(cycleTimer);
            cycleTimer = null;
        }
    }

    async function cycleToNext(currentIndex: number) {
        const remaining = getRemainingLocations();
        if (remaining.length === 0 || animating) return;

        const idx = currentIndex % remaining.length;
        const loc = remaining[idx].location;

        await animateToLocation(globe.getCamera(), loc.lat, loc.lon, FRAME_RADIUS, FLY_DURATION);

        const nextIdx = (idx + 1) % Math.max(remaining.length, 1);
        cycleTimer = setTimeout(() => cycleToNext(nextIdx), DWELL_TIME);
    }

    function beginRound() {
        const locations = startRound(globe, EUROPEAN_CAPITALS_SET, ROUND_SIZE);
        createSidebar(locations);
        createTimer(ROUND_TIME, onTimeUp, getSidebarWidth());
        startCycling();
    }

    function onTimeUp() {
        stopCycling();
        onRoundComplete();
    }

    async function onGuess(text: string, username: string) {
        const match = processGuess(text);
        if (!match) return;

        stopCycling();
        animating = true;

        await Promise.all([
            playCorrectEffect(globe, match.markerId),
            revealLocation(match.index, username),
        ]);

        animating = false;
        updateCounter(getGuessedCount(), getRoundTotal());

        if (isRoundComplete()) {
            onRoundComplete();
        } else {
            startCycling();
        }
    }

    function onRoundComplete() {
        disposeTimer();
        showCompletion();

        const overlay = document.createElement('div');
        overlay.style.cssText =
            'position:fixed;inset:0;z-index:100;display:flex;align-items:center;' +
            'justify-content:center;background:rgba(0,0,0,0.5);';

        const card = document.createElement('div');
        card.style.cssText =
            'background:rgba(20,20,30,0.95);border-radius:16px;padding:40px 48px;' +
            'text-align:center;font-family:system-ui,sans-serif;color:#fff;' +
            'backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);' +
            'border:1px solid rgba(255,255,255,0.1);';

        const title = document.createElement('div');
        title.style.cssText = 'font-size:28px;font-weight:700;margin-bottom:24px;color:#4CAF50;';
        title.textContent = 'Round Complete!';
        card.appendChild(title);

        const btn = document.createElement('button');
        btn.style.cssText =
            'padding:12px 32px;font-size:16px;font-weight:600;border:none;' +
            'border-radius:24px;background:#4CAF50;color:#fff;cursor:pointer;' +
            'transition:transform 0.15s;';
        btn.textContent = 'Play Again';
        btn.onmouseenter = () => btn.style.transform = 'scale(1.05)';
        btn.onmouseleave = () => btn.style.transform = 'scale(1)';
        btn.onclick = () => {
            overlay.remove();
            resetRound(globe);
            disposeSidebar();
            disposeTimer();
            beginRound();
        };
        card.appendChild(btn);

        overlay.appendChild(card);
        document.body.appendChild(overlay);

        startConfetti(document.body, card, 3);
    }
</script>
