---
import medalsData from '../../../public-prod/medals.json';
import type { MenuNode, Medal } from '../../medals/types';

const medals = medalsData.medals as Medal[];
const menu = medalsData.menu as MenuNode[];

const medalsById = new Map<number, Medal>();
for (const m of medals) {
    medalsById.set(m.id, m);
}

function getMedalBadge(medal: Medal): string {
    const count = medal.questionIds.length;
    switch (medal.type) {
        case 'countries': return `${count} countries`;
        case 'capitals': return `${count} capitals`;
        case 'provinces': return `${count} provinces`;
        case 'flags': return `${count} flags`;
        default: return `${count} sights`;
    }
}

function getMedalData(medalId: number) {
    const medal = medalsById.get(medalId);
    if (!medal) return null;
    return {
        id: medal.id,
        name: medal.name,
        badge: getMedalBadge(medal),
        type: medal.type,
        questionIds: medal.questionIds,
        countryISO2: medal.countryISO2,
    };
}
---

<div id="medals-menu">
    <div class="search-bar">
        <input type="text" id="search-input" placeholder="Search medals..." />
    </div>
    <div class="menu-container">
        {menu.map((node, i) => (
            <div class="menu-folder" data-depth="0">
                {'children' in node ? (
                    <>
                        <div class="menu-header depth-0 collapsed">{node.name}</div>
                        <div class="menu-children" style="display: none;">
                            {node.children.map((child) => (
                                'children' in child ? (
                                    <div class="menu-folder" data-depth="1">
                                        <div class="menu-header depth-1">{child.name}</div>
                                        <div class="menu-children">
                                            {child.children.map((leaf) => {
                                                if ('medalId' in leaf) {
                                                    const data = getMedalData(leaf.medalId);
                                                    if (!data) return null;
                                                    return (
                                                        <div
                                                            class="medal-leaf"
                                                            data-medal-id={data.id}
                                                            data-medal-name={data.name.toLowerCase()}
                                                            data-medal-type={data.type}
                                                            data-question-ids={JSON.stringify(data.questionIds)}
                                                            data-country-iso2={data.countryISO2 || ''}
                                                        >
                                                            <span class="medal-name">{leaf.name}</span>
                                                            <span class="medal-badge">{data.badge}</span>
                                                        </div>
                                                    );
                                                }
                                                return null;
                                            })}
                                        </div>
                                    </div>
                                ) : 'medalId' in child ? (
                                    (() => {
                                        const data = getMedalData(child.medalId);
                                        if (!data) return null;
                                        return (
                                            <div
                                                class="medal-leaf"
                                                data-medal-id={data.id}
                                                data-medal-name={data.name.toLowerCase()}
                                                data-medal-type={data.type}
                                                data-question-ids={JSON.stringify(data.questionIds)}
                                                data-country-iso2={data.countryISO2 || ''}
                                            >
                                                <span class="medal-name">{child.name}</span>
                                                <span class="medal-badge">{data.badge}</span>
                                            </div>
                                        );
                                    })()
                                ) : null
                            ))}
                        </div>
                    </>
                ) : 'medalId' in node ? (
                    (() => {
                        const data = getMedalData(node.medalId);
                        if (!data) return null;
                        return (
                            <div
                                class="medal-leaf"
                                data-medal-id={data.id}
                                data-medal-name={data.name.toLowerCase()}
                                data-medal-type={data.type}
                                data-question-ids={JSON.stringify(data.questionIds)}
                                data-country-iso2={data.countryISO2 || ''}
                            >
                                <span class="medal-name">{node.name}</span>
                                <span class="medal-badge">{data.badge}</span>
                            </div>
                        );
                    })()
                ) : null}
            </div>
        ))}
    </div>
    <div class="empty-message" style="display: none;">No medals found</div>
</div>
<canvas id="medalsCanvas"></canvas>

<style>
    #medalsCanvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        touch-action: none;
        display: none;
    }
    #medals-menu {
        max-width: 600px;
        margin: 0 auto;
        padding: 20px 16px;
    }
    .search-bar {
        margin-bottom: 16px;
    }
    .search-bar input {
        width: 100%;
        padding: 10px 14px;
        font-size: 16px;
        border: 1px solid #333;
        border-radius: 8px;
        background: #16213e;
        color: #e0e0e0;
        outline: none;
    }
    .search-bar input:focus {
        border-color: #4a90d9;
    }
    .menu-container {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }
    .menu-header {
        padding: 12px 14px;
        cursor: pointer;
        user-select: none;
        border-radius: 6px;
        font-weight: 600;
        transition: background 0.15s;
    }
    .menu-header:hover {
        background: rgba(255, 255, 255, 0.08);
    }
    .menu-header::before {
        content: '▾ ';
        display: inline-block;
        transition: transform 0.15s;
    }
    .menu-header.collapsed::before {
        transform: rotate(-90deg);
    }
    .depth-0 {
        font-size: 15px;
        color: #8ab4f8;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .depth-1 {
        font-size: 14px;
        color: #aaa;
        padding-left: 24px;
    }
    .menu-children {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }
    .medal-leaf {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 14px 10px 28px;
        cursor: pointer;
        border-radius: 6px;
        transition: background 0.15s;
    }
    .medal-leaf:hover,
    .medal-leaf.selected {
        background: rgba(74, 144, 217, 0.15);
    }
    .medal-leaf.selected {
        outline: 2px solid #4a90d9;
        outline-offset: -2px;
    }
    .medal-name {
        font-size: 14px;
    }
    .medal-badge {
        font-size: 12px;
        color: #888;
        white-space: nowrap;
        margin-left: 12px;
    }
    .empty-message {
        text-align: center;
        color: #666;
        padding: 40px 0;
        font-size: 14px;
    }
    .menu-folder.hidden,
    .medal-leaf.hidden {
        display: none;
    }
</style>

<script>
    import { initMobile } from '../../shared/ui/mobile-init.ts';
    import { showEndGameOverlay } from '../../shared/ui/end-game-overlay.ts';
    import { asset } from '../../shared/asset-path.ts';
    import type { Question } from '../../shared/quiz/quiz-types.ts';
    import type { LocationsData } from '../../medals/types.ts';
    import { MEDALS_I18N } from './i18n.ts';
    import { COUNTRY_NAMES } from '../../shared/i18n/country-names.ts';
    import { initI18n, getLocale } from '../../shared/i18n/i18n.ts';

    // Apply medals-specific body styles (avoid CSS global leakage)
    document.body.style.fontFamily = "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif";
    document.body.style.background = '#1a1a2e';
    document.body.style.color = '#e0e0e0';

    // Initialize i18n early so getLocale() works for country names
    initI18n(MEDALS_I18N);

    initMobile();

    const menuEl = document.getElementById('medals-menu')!;
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const emptyMessage = menuEl.querySelector('.empty-message') as HTMLElement;
    const canvas = document.getElementById('medalsCanvas') as HTMLCanvasElement;

    // Lazy-loaded data for quiz
    let locationsData: LocationsData | null = null;

    // Toggle folders
    menuEl.querySelectorAll('.menu-header').forEach((header) => {
        header.addEventListener('click', () => {
            const children = header.nextElementSibling as HTMLElement;
            if (!children) return;
            const isHidden = children.style.display === 'none';
            children.style.display = isHidden ? '' : 'none';
            header.classList.toggle('collapsed', !isHidden);
        });
    });

    // Search
    searchInput.addEventListener('input', () => {
        const query = searchInput.value.trim().toLowerCase();
        const allLeaves = menuEl.querySelectorAll('.medal-leaf');
        const allFolders = menuEl.querySelectorAll('.menu-folder');

        if (!query) {
            // Reset: show all, collapse top-level
            allLeaves.forEach((el) => el.classList.remove('hidden'));
            allFolders.forEach((el) => el.classList.remove('hidden'));
            menuEl.querySelectorAll('.menu-header.depth-0').forEach((header) => {
                const children = header.nextElementSibling as HTMLElement;
                if (children) {
                    children.style.display = 'none';
                    header.classList.add('collapsed');
                }
            });
            emptyMessage.style.display = 'none';
            return;
        }

        // Filter medals
        let anyVisible = false;
        allLeaves.forEach((leaf) => {
            const name = leaf.getAttribute('data-medal-name') || '';
            const matches = name.includes(query);
            leaf.classList.toggle('hidden', !matches);
            if (matches) anyVisible = true;
        });

        // Show/hide folders based on visible children, expand matching
        allFolders.forEach((folder) => {
            const visibleChildren = folder.querySelectorAll('.medal-leaf:not(.hidden)');
            folder.classList.toggle('hidden', visibleChildren.length === 0);

            // Expand folders with matches
            const header = folder.querySelector('.menu-header');
            const children = folder.querySelector('.menu-children') as HTMLElement;
            if (header && children && visibleChildren.length > 0) {
                children.style.display = '';
                header.classList.remove('collapsed');
            }
        });

        emptyMessage.style.display = anyVisible ? 'none' : 'block';
    });

    // Click to start medal
    menuEl.querySelectorAll('.medal-leaf').forEach((leaf) => {
        leaf.addEventListener('click', () => startMedal(leaf as HTMLElement));
    });

    async function startMedal(el: HTMLElement) {
        const medalId = parseInt(el.getAttribute('data-medal-id') || '0');
        const medalName = el.querySelector('.medal-name')?.textContent || 'Quiz';
        const type = el.getAttribute('data-medal-type') || 'countries';
        const questionIds = JSON.parse(el.getAttribute('data-question-ids') || '[]');
        const countryISO2 = el.getAttribute('data-country-iso2') || '';

        // Update URL hash
        const slug = `${medalId}-${medalName.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '')}`;
        window.location.hash = slug;

        // Get localized country names
        const locale = getLocale();
        const countryNames = COUNTRY_NAMES[locale] || COUNTRY_NAMES['en'];

        const questions: Question[] = [];

        if (type === 'countries') {
            for (const iso2 of questionIds) {
                const name = countryNames[iso2];
                if (!name) continue;
                questions.push({
                    present: 'text',
                    answer: 'country',
                    countryISO2: iso2,
                    prompt: name,
                });
            }
        } else if (type === 'provinces') {
            const provinceRes = await fetch(asset(`provinces/${countryISO2}.json`));
            const provinceData: { provinces: { id: number; name: string }[] } = await provinceRes.json();
            const provinceNames = new Map(provinceData.provinces.map((p) => [p.id, p.name]));

            for (const provinceId of questionIds) {
                const name = provinceNames.get(provinceId as number);
                if (!name) continue;
                questions.push({
                    present: 'text',
                    answer: 'province',
                    provinceId: provinceId as number,
                    countryISO2,
                    prompt: name,
                });
            }
        } else if (type === 'flags') {
            for (const iso2 of questionIds) {
                questions.push({
                    present: 'image',
                    answer: 'country',
                    countryISO2: iso2 as string,
                    imageUrl: asset(`_flags/${iso2}.png`),
                    imageFrame: 'simple',
                    prompt: '',
                });
            }
        } else if (type === 'locations' || type === 'capitals') {
            if (!locationsData) {
                const res = await fetch(asset('locations.json'));
                locationsData = await res.json();
            }
            for (const locId of questionIds) {
                const loc = locationsData![locId as string];
                if (!loc) continue;
                questions.push({
                    present: 'text',
                    answer: 'location-alternatives',
                    lat: loc.lat,
                    lng: loc.lng,
                    prompt: loc.name,
                });
            }
        }

        // Switch to game view
        menuEl.style.display = 'none';
        document.body.style.overflow = 'hidden';
        canvas.style.display = 'block';

        const { startQuizGame } = await import('../../solo/start-quiz-game.ts');

        await startQuizGame({
            canvasId: 'medalsCanvas',
            title: medalName,
            questions,
            scoreBarType: 'simple',
            i18n: MEDALS_I18N,
            onGameComplete: (score, total, elapsedMs) => {
                showEndGameOverlay(
                    score,
                    total,
                    elapsedMs,
                    () => startMedal(el),
                    () => {
                        window.location.hash = '';
                        window.location.reload();
                    }
                );
            },
        });
    }

    // Handle direct link via hash
    const hash = window.location.hash;
    if (hash) {
        const match = hash.match(/^#(\d+)/);
        if (match) {
            const medalId = match[1];
            const leaf = menuEl.querySelector(`[data-medal-id="${medalId}"]`) as HTMLElement;
            if (leaf) startMedal(leaf);
        }
    } else {
        searchInput.focus();
    }
</script>
