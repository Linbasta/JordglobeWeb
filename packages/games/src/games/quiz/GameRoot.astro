---
import { quizBySlug } from './quiz-manifests';

const { quizSlug } = Astro.props;
const quiz = quizBySlug.get(quizSlug);
if (!quiz) throw new Error(`Unknown quiz slug: ${quizSlug}`);
---

<canvas
    id="quizCanvas"
    data-quiz={JSON.stringify(quiz)}
    data-quiz-slug={quizSlug}
></canvas>

<style>
    #quizCanvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        touch-action: none;
    }
</style>

<script>
    import { initMobile } from '../../shared/ui/mobile-init.ts';
    import { QUIZ_I18N } from './i18n.ts';
    import { initI18n } from '../../shared/i18n/i18n.ts';
    import { buildQuestions } from './build-questions.ts';
    import type { QuizDef } from '../../quiz/types.ts';

    initI18n(QUIZ_I18N);
    initMobile();

    document.body.style.overflow = 'hidden';

    const canvas = document.getElementById('quizCanvas') as HTMLCanvasElement;
    const quiz: QuizDef = JSON.parse(canvas.dataset.quiz!);
    const quizId = `quiz-${canvas.dataset.quizSlug!}`;

    async function startQuiz() {
        const questions = await buildQuestions(quiz);
        const { startQuizGame } = await import('../../solo/start-quiz-game.ts');
        const allCountryAnswers = questions.every((q) => q.answer === 'country');

        await startQuizGame({
            canvasId: 'quizCanvas',
            title: quiz.name,
            questions,
            scoreBarType: 'simple',
            i18n: QUIZ_I18N,
            quizId,
            onGameComplete: async (score, total, elapsedMs, results, isPersonalBest) => {
                const [{ showResultOverlay }, { DEFAULT_SCORE_LEVEL_SPRITES, getDefaultTierNames }, { iso2ToFlag }] = await Promise.all([
                    import('../../shared/ui/result-overlay.ts'),
                    import('../../shared/ui/default-score-levels.ts'),
                    import('../../shared/ui/share-message.ts'),
                ]);

                const spriteNames = getDefaultTierNames();
                showResultOverlay({
                    score,
                    total,
                    elapsedMs,
                    results,
                    quizTitle: quiz.name,
                    shareUrl: window.location.href,
                    sprites: DEFAULT_SCORE_LEVEL_SPRITES,
                    spriteNames,
                    isPersonalBest,
                    formatShareSquares: allCountryAnswers
                        ? (rs) =>
                            rs
                                .map((correct, i) =>
                                    correct && questions[i].countryISO2
                                        ? iso2ToFlag(questions[i].countryISO2!)
                                        : '🟥',
                                )
                                .join('')
                        : undefined,
                    onSeeRanking: async () => {
                        const { showLeaderboardWithAuth } = await import('../../shared/ui/leaderboard-popup.ts');
                        showLeaderboardWithAuth({
                            quizId,
                            userScore: score,
                            userTotal: total,
                            userElapsedMs: elapsedMs,
                            isPersonalBest,
                            onClose: () => {},
                        });
                    },
                    onRetry: () => startQuiz(),
                });
            },
        });
    }

    startQuiz();
</script>
