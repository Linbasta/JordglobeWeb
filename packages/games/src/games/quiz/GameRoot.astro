---
import { quizBySlug } from './quiz-manifests';

const { quizSlug } = Astro.props;
const quiz = quizBySlug.get(quizSlug);
if (!quiz) throw new Error(`Unknown quiz slug: ${quizSlug}`);
---

<canvas
    id="quizCanvas"
    data-quiz={JSON.stringify(quiz)}
></canvas>

<style>
    #quizCanvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        touch-action: none;
    }
</style>

<script>
    import { initMobile } from '../../shared/ui/mobile-init.ts';
    import { showEndGameOverlay } from '../../shared/ui/end-game-overlay.ts';
    import { QUIZ_I18N } from './i18n.ts';
    import { initI18n } from '../../shared/i18n/i18n.ts';
    import { buildQuestions } from './build-questions.ts';
    import type { QuizDef } from '../../quiz/types.ts';

    initI18n(QUIZ_I18N);
    initMobile();

    document.body.style.overflow = 'hidden';

    const canvas = document.getElementById('quizCanvas') as HTMLCanvasElement;
    const quiz: QuizDef = JSON.parse(canvas.dataset.quiz!);

    async function startQuiz() {
        const questions = await buildQuestions(quiz);
        const { startQuizGame } = await import('../../solo/start-quiz-game.ts');

        await startQuizGame({
            canvasId: 'quizCanvas',
            title: quiz.name,
            questions,
            scoreBarType: 'simple',
            i18n: QUIZ_I18N,
            onGameComplete: (score, total, elapsedMs) => {
                showEndGameOverlay(
                    score,
                    total,
                    elapsedMs,
                    () => startQuiz(),
                    () => { window.history.back(); }
                );
            },
        });
    }

    startQuiz();
</script>
