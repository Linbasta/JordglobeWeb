{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "@jordglobe/games#build:astro": {
      "inputs": [
        "src/**",
        "public-prod/**",
        "astro.config.mjs",
        "package.json",
        "tsconfig.json"
      ],
      "outputs": ["dist/**"],
      "env": ["NODE_ENV"]
    },
    "@jordglobe/site#build": {
      "inputs": [
        "src/**",
        "public/**",
        "scripts/**",
        "astro.config.mjs",
        "tsconfig.json",
        "package.json",
        "$TURBO_ROOT$/packages/games/src/games/**"
      ],
      "outputs": ["dist/**"],
      "env": ["NODE_ENV"]
    },
    "@jordglobe/site#deploy:stage": {
      "dependsOn": [
        "@jordglobe/site#build",
        "@jordglobe/games#build:astro"
      ],
      "cache": false
    },
    "@jordglobe/site#deploy:prod": {
      "dependsOn": [
        "@jordglobe/site#build",
        "@jordglobe/games#build:astro"
      ],
      "cache": false
    },
    "@jordglobe/site#preview": {
      "dependsOn": [
        "@jordglobe/site#build",
        "@jordglobe/games#build:astro"
      ],
      "cache": false,
      "persistent": true
    }
  }
}
