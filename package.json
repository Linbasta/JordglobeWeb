{
	"name": "nova",
	"type": "module",
	"version": "3.0.0",
	"scripts": {
		"dev": "node ./scripts/copy-pages.js && astro dev --host",
		"start": "node ./scripts/copy-pages.js && astro dev --host",
		"build": "node ./scripts/copy-pages.js && astro build",
		"preview": "astro preview",
		"astro": "astro",
		"config-i18n": "node ./scripts/config-i18n.js",
		"remove-keystatic": "node ./scripts/remove-keystatic.js",
		"format": "prettier -w \"**/*\" --ignore-unknown --cache",
		"copy-pages": "node ./scripts/copy-pages.js",
		"deploy:stage": "npm run build && firebase deploy --only hosting:stage",
		"deploy:prod": "npm run build && firebase deploy --only hosting:prod"
	},
	"dependencies": {
		"@astrojs/mdx": "^4.0.8",
		"@astrojs/netlify": "^6.1.0",
		"@astrojs/node": "^9.2.2",
		"@astrojs/react": "^4.2.0",
		"@astrojs/rss": "^4.0.11",
		"@astrojs/sitemap": "^3.2.1",
		"@fontsource-variable/inter": "^5.1.0",
		"@fontsource/inter": "^5.1.0",
		"@keystatic/astro": "^5.0.3",
		"@keystatic/core": "^0.5.41",
		"@tabler/icons": "^3.30.0",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/vite": "^4.0.5",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"animejs": "^3.2.2",
		"astro": "^5.3.0",
		"astro-auto-import": "^0.4.4",
		"astro-icon": "1.1.4",
		"astro-seo": "^0.8.4",
		"detect-browser": "^5.3.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"swiper": "^11.1.15",
		"tailwindcss": "^4.0.5",
		"tailwindcss-animate": "^1.0.7"
	},
	"devDependencies": {
		"@playform/compress": "^0.1.6",
		"lodash.debounce": "^4.0.8",
		"lodash.throttle": "^4.1.1",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-tailwindcss": "^0.6.9"
	},
	"overrides": {
		"sharp": "^0.33.0"
	}
}
