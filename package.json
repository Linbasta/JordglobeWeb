{
  "name": "jordglobe",
  "version": "1.0.0",
  "private": true,
  "description": "JordGlobe monorepo - geography learning platform",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@firebase/util",
      "@parcel/watcher",
      "better-sqlite3",
      "esbuild",
      "protobufjs",
      "sharp"
    ]
  },
  "scripts": {
    "dev": "pnpm dev:site & pnpm dev:games",
    "dev:all": "pnpm dev:site & pnpm dev:games",
    "dev:games": "pnpm --filter @jordglobe/games dev",
    "dev:site": "pnpm --filter @jordglobe/site dev",
    "dev:party-server": "pnpm --filter @jordglobe/party-server dev",
    "log-server": "pnpm --filter @jordglobe/games log-server",
    "build:games": "pnpm --filter @jordglobe/games build",
    "build:site": "turbo run build --filter=@jordglobe/site",
    "build:games:astro": "turbo run build:astro --filter=@jordglobe/games",
    "deploy:stage": "turbo run deploy:stage --filter=@jordglobe/site",
    "deploy:games:stage": "pnpm --filter @jordglobe/games deploy:stage",
    "deploy:prod": "turbo run deploy:prod --filter=@jordglobe/site",
    "preview": "turbo run preview --filter=@jordglobe/site"
  },
  "keywords": [
    "geography",
    "quiz",
    "learning",
    "globe"
  ],
  "author": "",
  "license": "PRIVATE",
  "devDependencies": {
    "turbo": "^2.9.6",
    "wrangler": "^4"
  }
}
