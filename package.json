{
  "name": "jordglobe",
  "version": "1.0.0",
  "private": true,
  "description": "JordGlobe monorepo - geography learning platform",
  "type": "module",
  "scripts": {
    "dev:games": "pnpm --filter @jordglobe/games dev",
    "dev:site": "pnpm --filter @jordglobe/site dev",
    "build:games": "pnpm --filter @jordglobe/games build",
    "build:site": "pnpm --filter @jordglobe/site build",
    "build:eurovision-embedded": "GAMES_SEO_CONFIG_PATH=$PWD/shared/games-seo.json pnpm --filter @jordglobe/games build:eurovision-embedded",
    "deploy:stage": "pnpm build:eurovision-embedded && pnpm --filter @jordglobe/site deploy:stage",
    "deploy:prod": "pnpm build:eurovision-embedded && pnpm --filter @jordglobe/site deploy:prod"
  },
  "keywords": ["geography", "quiz", "learning", "globe"],
  "author": "",
  "license": "PRIVATE"
}
